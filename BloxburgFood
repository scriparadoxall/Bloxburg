local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

_G.BloxburgChef = {}
local isRunning = false
local currentMacroId = 0
local selectedFood = "Hot Dogs"

-- === FILTRO DE SEGURANÇA: ENCONTRAR APENAS O SEU LOTE ===
local function GetMyOwnPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    
    -- Tenta encontrar o lote que pertence a você
    for _, plot in pairs(plots:GetChildren()) do
        -- No Bloxburg, o lote costuma ter o nome do jogador ou um atributo de Owner
        if plot:FindFirstChild("Occupant") and plot.Occupant.Value == LocalPlayer.Name then
            return plot
        elseif string.find(plot.Name, LocalPlayer.Name) then
            return plot
        end
    end
    
    -- Fallback: Se não achar pelo nome, pega o que o boneco está pisando em cima
    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("House") then
            local pPos = plot:GetPivot().Position
            local charPos = LocalPlayer.Character.HumanoidRootPart.Position
            if (Vector3.new(pPos.X, 0, pPos.Z) - Vector3.new(charPos.X, 0, charPos.Z)).Magnitude < 50 then
                return plot
            end
        end
    end
    return nil
end

-- === LOCALIZADOR PRECISO (Só olha dentro da sua House -> Counters) ===
local function FindMyStation(stationName)
    local myPlot = GetMyOwnPlot()
    if not myPlot then 
        print("Erro: Não encontrei o seu lote!")
        return nil 
    end
    
    -- Caminho exato da sua imagem 25781: Plot -> House -> Counters
    local countersFolder = myPlot:FindFirstChild("House") and myPlot.House:FindFirstChild("Counters")
    if not countersFolder then return nil end

    local target = nil
    local shortestDist = math.huge
    
    for _, obj in pairs(countersFolder:GetChildren()) do
        if obj.Name == stationName then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - obj:GetPivot().Position).Magnitude
            if d < shortestDist then
                shortestDist = d
                target = obj
            end
        end
    end
    return target
end

-- === AJUSTE DE CÂMERA HUMANA (PARA O FOGÃO) ===
local function AimAtObject(obj)
    local targetPos = obj:GetPivot().Position
    -- Mira no centro do fogão/bancada para o 'E' aparecer
    local lookTarget = targetPos + Vector3.new(0, -0.5, 0) 
    
    local tween = TweenService:Create(Camera, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        CFrame = CFrame.lookAt(Camera.CFrame.Position, lookTarget)
    })
    tween:Play()
    task.wait(0.5)
end

-- === MOVIMENTAÇÃO RESTRETA AO LOTE ===
local function MoveToStation(name)
    local station = FindMyStation(name)
    if not station then return false end
    
    local hrp = LocalPlayer.Character.HumanoidRootPart
    local hum = LocalPlayer.Character.Humanoid
    local targetPos = station:GetPivot().Position
    
    -- Posição de paragem calculada
    local dir = (hrp.Position - targetPos).Unit
    local walkPos = targetPos + (dir * 3.2)
    
    hum:MoveTo(walkPos)
    
    local t = 0
    while (hrp.Position - walkPos).Magnitude > 1.5 and t < 60 do
        task.wait(0.1); t = t + 1
    end
    
    -- Vira e foca a visão
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    AimAtObject(station)
    
    task.wait(0.2)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    return true
end

-- === START/STOP ===
function _G.BloxburgChef.Start(food)
    selectedFood = food or "Hot Dogs"
    isRunning = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId
    
    task.spawn(function()
        while isRunning and currentMacroId == myId do
            -- Agora ele só vai procurar na SUA pasta Counters
            if MoveToStation("Icebox Fridge") then
                task.wait(2)
                -- Lógica do menu aqui...
            end
            
            task.wait(1)
            
            -- Vai para o fogão/bancada conforme o que estiver na mão
            -- Mas sempre dentro do SEU lote!
            MoveToStation("Basic Stove")
            
            task.wait(2)
        end
    end)
end

function _G.BloxburgChef.Stop()
    isRunning = false
    currentMacroId = currentMacroId + 1
end
