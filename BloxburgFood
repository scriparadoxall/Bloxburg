local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

_G.BloxburgChef = {}
local isRunning = false
local currentMacroId = 0
local selectedFood = "Hot Dogs"

-- === SISTEMA DE VISÃO HUMANA (Ajusta a sua câmera real) ===
local function AdjustCameraToObject(targetInstance)
    local targetPos = targetInstance:GetPivot().Position
    
    -- Bloxburg só mostra o "E" se o centro da tela bater no objeto.
    -- Vamos mirar um pouco abaixo do topo do fogão (onde ficam as bocas)
    local lookTarget = targetPos + Vector3.new(0, -0.2, 0)
    
    -- Suaviza o movimento da sua câmera para parecer humano
    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = {CFrame = CFrame.lookAt(Camera.CFrame.Position, lookTarget)}
    
    local tween = TweenService:Create(Camera, tweenInfo, goal)
    tween:Play()
    task.wait(0.5) -- Espera a visão alinhar
end

-- === LOCALIZADOR POR PASTA (Conforme sua imagem do Explorer) ===
local function GetMyPlot()
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        if string.find(plot.Name, LocalPlayer.Name) or plot:FindFirstChild("House") then
            return plot
        end
    end
end

local function FindStation(name)
    local plot = GetMyPlot()
    if plot and plot.House:FindFirstChild("Counters") then
        local counters = plot.House.Counters:GetChildren()
        local closest = nil
        local dist = math.huge
        for _, obj in pairs(counters) do
            if obj.Name == name then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - obj:GetPivot().Position).Magnitude
                if d < dist then dist = d; closest = obj end
            end
        end
        return closest
    end
end

-- === MOVIMENTAÇÃO E INTERAÇÃO ===
local function GoToAndInteract(objectName)
    local obj = FindStation(objectName)
    if not obj then return false end
    
    local hrp = LocalPlayer.Character.HumanoidRootPart
    local hum = LocalPlayer.Character.Humanoid
    local targetPos = obj:GetPivot().Position
    
    -- Calcula posição de parada (frente ao fogão)
    local offset = (hrp.Position - targetPos).Unit * 3.2
    local walkPos = targetPos + Vector3.new(offset.X, 0, offset.Z)
    
    hum:MoveTo(walkPos)
    local timeout = 0
    while (hrp.Position - walkPos).Magnitude > 1.5 and timeout < 50 do
        task.wait(0.1); timeout = timeout + 1
    end
    
    -- A MÁGICA: Vira o corpo e arruma a visão da sua câmera
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    AdjustCameraToObject(obj)
    
    task.wait(0.2)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    return true
end

-- === LOOP PRINCIPAL ===
function _G.BloxburgChef.Start(food)
    selectedFood = food or "Hot Dogs"
    isRunning = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId
    
    task.spawn(function()
        while isRunning and currentMacroId == myId do
            -- 1. Vai na Geladeira
            GoToAndInteract("Icebox Fridge")
            task.wait(2)
            
            -- (Aqui entra a lógica de clicar no menu que já tínhamos)
            -- 2. Cozinha (Exemplo com Fogão)
            GoToAndInteract("Basic Stove")
            
            -- Simula o minigame clicando na tela
            local start = tick()
            while tick() - start < 15 do
                local float = LocalPlayer.PlayerGui:FindFirstChild("FloatingGui")
                if float then
                    -- Clica nos botões que aparecem na sua tela
                    for _, b in pairs(float:GetDescendants()) do
                        if b:IsA("GuiButton") and b.Visible then
                            -- Força o clique humano
                            local pos = b.AbsolutePosition + (b.AbsoluteSize/2)
                            VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y + 58, 0, true, game, 1)
                            task.wait(0.05)
                            VirtualInputManager:SendMouseButtonEvent(pos.X, pos.Y + 58, 0, false, game, 1)
                        end
                    end
                end
                task.wait(0.2)
            end
            task.wait(1)
        end
    end)
end

function _G.BloxburgChef.Stop()
    isRunning = false
    currentMacroId = currentMacroId + 1
end
