local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")
local GuiService = game:GetService("GuiService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera

_G.BloxburgChef = {}
local isRunning = false
local currentMacroId = 0
local selectedFood = "Hot Dogs"

-- === DICIONÁRIOS DE AÇÕES ===
local validActions = {
    "fry", "bake", "cook", "prepare", "stir", "mix", "chop", 
    "cut", "pour", "form", "garnish", "boil", "add", "blend",
    "fritar", "assar", "cozinhar", "preparar", "mexer", "misturar", "cortar",
    "picar", "despejar", "formar", "modelar", "decorar", "guarnecer", "ferver", 
    "adicionar", "bater"
}

local finishedActions = {
    "eat", "place", "take portion", "store",
    "comer", "colocar", "pegar porção", "guardar"
}

local function Log(texto, cor)
    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog(texto, cor) else print("[Chef] " .. texto) end
end

-- === CLIQUE FORÇADO ===
local function ForceClick(element)
    if not element or not element.Visible then return end
    pcall(function()
        if element.MouseButton1Click then for _, conn in pairs(getconnections(element.MouseButton1Click)) do conn:Fire() end end
        if element.Activated then for _, conn in pairs(getconnections(element.Activated)) do conn:Fire() end end
        if element.InputBegan then for _, conn in pairs(getconnections(element.InputBegan)) do conn:Fire({UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.Begin}) end end
        if element.InputEnded then for _, conn in pairs(getconnections(element.InputEnded)) do conn:Fire({UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.End}) end end
    end)
    local center = element.AbsolutePosition + (element.AbsoluteSize / 2)
    local inset = GuiService:GetGuiInset()
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y + inset.Y, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y + inset.Y, 0, false, game, 1)
end

-- === FILTRO DE SEGURANÇA: ENCONTRAR APENAS O SEU LOTE ===
local function GetMyOwnPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    
    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("Occupant") and plot.Occupant.Value == LocalPlayer.Name then
            return plot
        elseif string.find(plot.Name, LocalPlayer.Name) then
            return plot
        end
    end
    
    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("House") then
            local pPos = plot:GetPivot().Position
            local charPos = LocalPlayer.Character.HumanoidRootPart.Position
            if (Vector3.new(pPos.X, 0, pPos.Z) - Vector3.new(charPos.X, 0, charPos.Z)).Magnitude < 50 then return plot end
        end
    end
    return nil
end

local function FindMyStation(stationName)
    local myPlot = GetMyOwnPlot()
    if not myPlot then return nil end
    
    local countersFolder = myPlot:FindFirstChild("House") and myPlot.House:FindFirstChild("Counters")
    if not countersFolder then return nil end

    local target = nil
    local shortestDist = math.huge
    
    for _, obj in pairs(countersFolder:GetChildren()) do
        if obj.Name == stationName then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - obj:GetPivot().Position).Magnitude
            if d < shortestDist then shortestDist = d; target = obj end
        end
    end
    return target
end

-- === AJUSTE DE CÂMERA HUMANA ===
local function AimAtObject(obj)
    local targetPos = obj:GetPivot().Position
    local lookTarget = targetPos + Vector3.new(0, -0.5, 0) 
    local tween = TweenService:Create(Camera, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {CFrame = CFrame.lookAt(Camera.CFrame.Position, lookTarget)})
    tween:Play()
    task.wait(0.5)
end

-- === MOVIMENTAÇÃO RESTRITA AO LOTE ===
local function MoveToStation(name)
    local station = FindMyStation(name)
    if not station then return false end
    
    local hrp = LocalPlayer.Character.HumanoidRootPart
    local hum = LocalPlayer.Character.Humanoid
    local targetPos = station:GetPivot().Position
    
    local dir = (hrp.Position - targetPos).Unit
    local walkPos = targetPos + (dir * 3.2)
    
    hum:MoveTo(walkPos)
    
    local t = 0
    while (hrp.Position - walkPos).Magnitude > 1.5 and t < 60 do
        if hum.MoveDirection.Magnitude < 0.1 then hum.Jump = true end
        task.wait(0.1); t = t + 1
    end
    
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    AimAtObject(station)
    
    task.wait(0.2)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    return true
end

-- === LOOP PRINCIPAL DE FARM ===
function _G.BloxburgChef.Start(food)
    if isRunning then return end
    selectedFood = food or "Hot Dogs"
    isRunning = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId
    
    Log("Farm Iniciado (Com Validação de Comida)", Color3.fromRGB(50, 255, 50))
    
    task.spawn(function()
        while isRunning and currentMacroId == myId do
            
            -- ==========================================
            -- 1. FASE DE PEGAR COMIDA (LOOP DE VALIDAÇÃO)
            -- ==========================================
            local hasFood = false
            
            while isRunning and currentMacroId == myId and not hasFood do
                if MoveToStation("Icebox Fridge") then
                    task.wait(1)
                    
                    -- Tenta clicar em "Take Ingredients"
                    local interactUI = PlayerGui:FindFirstChild("_interactUI")
                    if interactUI then
                        for _, el in pairs(interactUI:GetDescendants()) do
                            if el:IsA("TextLabel") and (string.lower(el.Text):find("take") or string.lower(el.Text):find("pegar")) then
                                ForceClick(el.Parent)
                                break
                            end
                        end
                    end
                    
                    task.wait(1.5)
                    
                    -- Tenta clicar na comida na lista
                    local listMenu = PlayerGui:FindFirstChild("_ListFrame (T_Ingredients)", true)
                    if listMenu then
                        local foodBtn = listMenu:FindFirstChild(selectedFood .. "_Button", true)
                        if foodBtn then
                            ForceClick(foodBtn:FindFirstChild("Take"))
                            local ev = listMenu:FindFirstChild("Frame") and listMenu.Frame:FindFirstChild("Event")
                            if ev then pcall(function() ev:Fire(foodBtn) end) end
                        end
                    end
                    
                    -- VALIDAÇÃO SCANNER (Espera até 4 segundos a comida ir para a mão)
                    Log("Lendo as mãos...", Color3.fromRGB(200, 200, 200))
                    for scan = 1, 40 do
                        if not isRunning or currentMacroId ~= myId then break end
                        
                        local equipped = PlayerGui:FindFirstChild("EquippedButton", true)
                        if equipped and equipped.Visible then
                            local actLbl = equipped:FindFirstChild("ActionLabel")
                            if actLbl and actLbl.Text ~= "" then
                                -- Converte tudo para minúsculo para não importar se está "Fry", "FRY" ou " fry "
                                local textInHand = string.lower(actLbl.Text) 
                                
                                for _, vAct in pairs(validActions) do
                                    if string.find(textInHand, string.lower(vAct)) then
                                        hasFood = true
                                        Log("Comida (" .. actLbl.Text .. ") confirmada!", Color3.fromRGB(50, 255, 50))
                                        break
                                    end
                                end
                            end
                        end
                        
                        if hasFood then break end
                        task.wait(0.1) -- Espera 0.1s e olha a mão de novo
                    end
                    
                    if not hasFood then
                        Log("Mão vazia. Falha ao pegar comida. Tentando novamente...", Color3.fromRGB(255, 100, 100))
                        task.wait(1.5) -- Pausa antes de tentar abrir a geladeira de novo
                    end
                else
                    Log("Não achei a geladeira no seu lote!", Color3.fromRGB(255, 50, 50))
                    task.wait(3)
                end
            end
            
            -- ==========================================
            -- 2. FASE DE COZINHAR (ESTAÇÕES)
            -- ==========================================
            local finished = false
            
            while isRunning and currentMacroId == myId and not finished do
                local equipped = PlayerGui:FindFirstChild("EquippedButton", true)
                if equipped and equipped.Visible then
                    local actLbl = equipped:FindFirstChild("ActionLabel")
                    if actLbl then
                        local act = string.lower(actLbl.Text) -- Sempre minúsculo
                        
                        -- Verifica se o prato acabou
                        for _, fAct in pairs(finishedActions) do
                            if string.find(act, string.lower(fAct)) then
                                Log("Prato Finalizado!", Color3.fromRGB(50, 255, 50))
                                finished = true
                                break
                            end
                        end
                        if finished then break end
                        
                        -- Descobre se precisa de Fogão ou Balcão
                        local isStove = string.find(act, "fry") or string.find(act, "boil") or string.find(act, "cook") or string.find(act, "bake") or string.find(act, "fritar") or string.find(act, "ferver") or string.find(act, "cozinhar") or string.find(act, "assar")
                        local targetName = isStove and "Basic Stove" or "Basic Counter"
                        
                        Log("GPS: Indo para " .. targetName .. " (" .. actLbl.Text .. ")", Color3.fromRGB(150, 200, 255))
                        
                        if MoveToStation(targetName) then
                            task.wait(0.5)
                            
                            -- LIMPEZA DE SUJEIRA
                            local interactUI = PlayerGui:FindFirstChild("_interactUI")
                            if interactUI then
                                for _, el in pairs(interactUI:GetDescendants()) do
                                    if el:IsA("TextLabel") and (string.lower(el.Text) == "clean" or string.lower(el.Text) == "limpar") then
                                        Log("Limpando sujeira...", Color3.fromRGB(255, 150, 50))
                                        ForceClick(el.Parent)
                                        task.wait(9)
                                        break
                                    end
                                end
                            end
                            
                            -- MINIGAME DE CLIQUE
                            local stageStart = tick()
                            while tick() - stageStart < 20 do
                                if not isRunning or currentMacroId ~= myId then break end
                                
                                local float = PlayerGui:FindFirstChild("FloatingGui")
                                if float then
                                    for _, b in pairs(float:GetDescendants()) do
                                        if b:IsA("GuiButton") and b.Visible then
                                            local letra = nil
                                            for _, c in pairs(b:GetDescendants()) do
                                                if c:IsA("TextLabel") and string.match(c.Text, "^%s*([A-Za-z])%s*$") then
                                                    letra = string.upper(string.match(c.Text, "^%s*([A-Za-z])%s*$"))
                                                    break
                                                end
                                            end
                                            if letra and letra ~= "E" then
                                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[letra], false, game)
                                                task.wait(0.05)
                                                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[letra], false, game)
                                            else
                                                ForceClick(b)
                                            end
                                        end
                                    end
                                end
                                
                                -- Verifica se a ação mudou ou acabou no meio do minigame
                                local currentAct = string.lower(actLbl.Text)
                                local endEarly = false
                                for _, fAct in pairs(finishedActions) do
                                    if string.find(currentAct, string.lower(fAct)) then
                                        finished = true
                                        endEarly = true
                                        break
                                    end
                                end
                                
                                if endEarly or currentAct ~= act then break end
                                
                                task.wait(0.2)
                            end
                        end
                    end
                end
                task.wait(0.5)
            end
        end
    end)
end

function _G.BloxburgChef.Stop()
    isRunning = false
    currentMacroId = currentMacroId + 1
end
