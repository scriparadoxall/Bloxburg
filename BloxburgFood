local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera

_G.BloxburgChef = {}
local isRunning = false
local currentMacroId = 0
local selectedFood = "Hot Dogs"

-- Sistema de Log
local function Log(texto, cor)
    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog(texto, cor) end
end

-- === ROTAÇÃO HUMANA ===
local function FaceObjectHumane(hrp, targetPos)
    -- Vira o boneco para o objeto (Isso já arrasta a câmera Custom junto)
    local newLook = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
    hrp.CFrame = CFrame.lookAt(hrp.Position, newLook)
    
    -- Dá um leve ajuste na câmera para ela olhar um pouco para baixo (ângulo de interação)
    -- Simulando o movimento do mouse/dedo do jogador
    local camPos = Camera.CFrame.Position
    local targetWithOffset = targetPos + Vector3.new(0, -1, 0) -- Olha para o meio do fogão
    
    -- Tween suave de 0.3 segundos para a câmera não dar "pulo"
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = {CFrame = CFrame.lookAt(camPos, targetWithOffset)}
    game:GetService("TweenService"):Create(Camera, tweenInfo, goal):Play()
end

local function WalkToTarget(hrp, humanoid, targetInstance)
    local targetPos = targetInstance:IsA("Model") and targetInstance:GetPivot().Position or targetInstance.Position
    
    -- Distância de braço (3 blocos)
    local direction = (hrp.Position - targetPos).Unit
    local finalPos = targetPos + (direction * 3)
    finalPos = Vector3.new(finalPos.X, hrp.Position.Y, finalPos.Z)
    
    humanoid:MoveTo(finalPos)
    
    local timeout = 0
    while (hrp.Position - finalPos).Magnitude > 1.5 and timeout < 100 do
        if humanoid.MoveDirection.Magnitude < 0.1 then humanoid.Jump = true end
        task.wait(0.1)
        timeout = timeout + 1
    end
    
    -- CHEGOU: Agora faz a virada humana
    FaceObjectHumane(hrp, targetPos)
    task.wait(0.3)
end

-- Lógica de Cliques e Botão Azul
local function PressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function ForceClick(element)
    if not element or not element.Visible then return end
    local center = element.AbsolutePosition + (element.AbsoluteSize / 2)
    local inset = GuiService:GetGuiInset()
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y + inset.Y, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y + inset.Y, 0, false, game, 1)
end

-- === CICLO DE COZINHA ===
local function RunFarmCycle(hrp, hum, myId)
    -- Busca a Geladeira mais próxima
    local fridge = nil; local dist = math.huge
    for _, item in pairs(workspace:GetDescendants()) do
        if item.Name == "Icebox Fridge" then
            local d = (hrp.Position - item:GetPivot().Position).Magnitude
            if d < dist then dist = d; fridge = item end
        end
    end

    if fridge then
        WalkToTarget(hrp, hum, fridge)
        task.wait(0.2)
        PressE()
        Log("Abrindo Geladeira...", Color3.fromRGB(255, 255, 255))
        
        -- Espera carregar a lista e clica em Ingredients
        task.wait(1.5)
        local listMenu = PlayerGui:FindFirstChild("_ListFrame (T_Ingredients)", true)
        if listMenu then
            local foodBtn = listMenu:FindFirstChild(selectedFood .. "_Button", true)
            if foodBtn then
                ForceClick(foodBtn:FindFirstChild("Take"))
                pcall(function() listMenu.Frame.Event:Fire(foodBtn) end)
            end
        end
    end

    -- Loop de Estações (Fogão/Balcão) baseado no texto do botão azul
    while isRunning and currentMacroId == myId do
        local equipped = PlayerGui:FindFirstChild("EquippedButton", true)
        if equipped and equipped.Visible then
            local actLbl = equipped:FindFirstChild("ActionLabel")
            if actLbl then
                local act = actLbl.Text:lower()
                
                -- Se aparecer Eat ou Place, acabou
                if act:find("eat") or act:find("place") or act:find("portion") then 
                    Log("Prato pronto!", Color3.fromRGB(50, 255, 50))
                    break 
                end
                
                -- Decide destino
                local isStove = act:find("fry") or act:find("boil") or act:find("cook") or act:find("bake")
                local targetName = isStove and "Basic Stove" or "Basic Counter"
                
                local station = nil; local sDist = math.huge
                for _, item in pairs(workspace:GetDescendants()) do
                    if item.Name == targetName then
                        local d = (hrp.Position - item:GetPivot().Position).Magnitude
                        if d < sDist then sDist = d; station = item end
                    end
                end
                
                if station then
                    WalkToTarget(hrp, hum, station)
                    task.wait(0.2)
                    PressE()
                    
                    -- Minigame (Clica em tudo que aparecer na FloatingGui)
                    local start = tick()
                    while tick() - start < 25 do
                        local float = PlayerGui:FindFirstChild("FloatingGui")
                        if float then
                            for _, b in pairs(float:GetDescendants()) do
                                if b:IsA("GuiButton") and b.Visible then ForceClick(b) end
                            end
                        end
                        -- Se o botão azul mudar de texto, significa que mudou a etapa
                        if actLbl.Text:lower() ~= act then break end
                        task.wait(0.2)
                    end
                end
            end
        end
        task.wait(0.5)
    end
end

-- === CONTROLES DO HUB ===
function _G.BloxburgChef.Start(foodName)
    if isRunning then return end
    selectedFood = foodName or "Hot Dogs"
    isRunning = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId
    Log("Farm Iniciado - Modo Humano", Color3.fromRGB(50, 255, 50))
    
    task.spawn(function()
        local char = LocalPlayer.Character
        local hrp = char:WaitForChild("HumanoidRootPart")
        local hum = char:WaitForChild("Humanoid")
        while isRunning and currentMacroId == myId do
            RunFarmCycle(hrp, hum, myId)
            task.wait(1)
        end
    end)
end

function _G.BloxburgChef.Stop()
    isRunning = false
    currentMacroId = currentMacroId + 1
    Log("Farm Parado", Color3.fromRGB(255, 100, 100))
end
