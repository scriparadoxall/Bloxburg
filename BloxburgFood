local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera

_G.BloxburgChef = {}
local isRunning = false
local currentMacroId = 0
local selectedFood = "Hot Dogs"

-- Dicionário Bilíngue de Ações Válidas para Clicar
local validActions = {
    "fry", "bake", "cook", "prepare", "stir", "mix", "chop", 
    "cut", "pour", "form", "garnish", "boil", "add", "blend",
    "fritar", "assar", "cozinhar", "preparar", "mexer", "misturar", "cortar",
    "picar", "despejar", "formar", "modelar", "decorar", "guarnecer", "ferver", 
    "adicionar", "bater"
}

-- Palavras que indicam que o prato ACABOU
local finishedActions = {
    "place", "take portion", "eat", "store",
    "colocar", "pegar porção", "comer", "guardar"
}

-- Sistema de Logs
local function Log(texto, cor)
    if _G.BloxburgChef_AddLog then
        _G.BloxburgChef_AddLog(texto, cor)
    else
        print("[Chef] " .. texto)
    end
end

-- Movimentação Perfeita
local function WalkToTarget(hrp, humanoid, targetInstance, distanceOffset)
    local targetCF = targetInstance:IsA("Model") and targetInstance:GetPivot() or targetInstance.CFrame
    local targetPos = targetCF.Position
    local standPos = (targetCF * CFrame.new(0, 0, distanceOffset)).Position
    local finalPos = Vector3.new(standPos.X, hrp.Position.Y, standPos.Z)
    
    Log("Caminhando até o alvo...", Color3.fromRGB(200, 200, 200))
    humanoid.WalkSpeed = 16
    humanoid:MoveTo(finalPos)
    
    local arrived = false
    local timeout = 0
    local camConnection = RunService.RenderStepped:Connect(function()
        if (hrp.Position - finalPos).Magnitude > 1.5 then
            local backPos = hrp.Position - (hrp.CFrame.LookVector * 7) + Vector3.new(0, 5, 0)
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(backPos, hrp.Position + hrp.CFrame.LookVector * 5), 0.1)
        else
            arrived = true
        end
    end)
    
    while not arrived and timeout < 100 do
        humanoid:MoveTo(finalPos) 
        timeout = timeout + 1
        task.wait(0.1)
    end
    
    camConnection:Disconnect()
    humanoid:MoveTo(hrp.Position) 
    
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
    Camera.CameraType = Enum.CameraType.Custom
    Camera.CFrame = CFrame.lookAt(hrp.Position - (hrp.CFrame.LookVector * 5) + Vector3.new(0, 3, 0), targetPos)
end

local function PressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function ForceClick(element)
    if not element or element.AbsoluteSize.X == 0 then return end
    pcall(function()
        if element.MouseButton1Click then for _, conn in pairs(getconnections(element.MouseButton1Click)) do conn:Fire() end end
        if element.Activated then for _, conn in pairs(getconnections(element.Activated)) do conn:Fire() end end
        if element.InputBegan then for _, conn in pairs(getconnections(element.InputBegan)) do conn:Fire({UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.Begin}) end end
        if element.InputEnded then for _, conn in pairs(getconnections(element.InputEnded)) do conn:Fire({UserInputType = Enum.UserInputType.MouseButton1, UserInputState = Enum.UserInputState.End}) end end
    end)
    local center = element.AbsolutePosition + (element.AbsoluteSize / 2)
    local inset = GuiService:GetGuiInset()
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y + inset.Y, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y + inset.Y, 0, false, game, 1)
end

-- === LOOP PRINCIPAL DE FARM ===
local function RunFarmCycle(hrp, hum, myId)
    -- ==========================================
    -- 1. GELADEIRA
    -- ==========================================
    local closestFridge = nil; local dist = math.huge
    for _, item in pairs(workspace:WaitForChild("Plots"):GetDescendants()) do
        if item.Name == "Icebox Fridge" then
            local d = (hrp.Position - item:GetPivot().Position).Magnitude
            if d < dist then dist = d; closestFridge = item end
        end
    end
    
    if closestFridge then
        WalkToTarget(hrp, hum, closestFridge, -3.5)
        task.wait(0.8); PressE()
        
        local interactUI = PlayerGui:WaitForChild("_interactUI", 5)
        if not interactUI then return false end

        local takeIngBtn = nil
        for i = 1, 30 do 
            if not isRunning or currentMacroId ~= myId then return false end
            for _, el in pairs(interactUI:GetDescendants()) do
                if el:IsA("TextLabel") then
                    local txt = el.Text:lower()
                    if txt == "take ingredients" or txt == "pegar ingredientes" then 
                        takeIngBtn = el.Parent; break 
                    end
                end
            end
            if takeIngBtn then break end; task.wait(0.1)
        end

        if not takeIngBtn then return false end

        local listMenu = nil
        for tentativa = 1, 5 do
            if not isRunning or currentMacroId ~= myId then return false end
            ForceClick(takeIngBtn)
            task.wait(1.2)
            listMenu = PlayerGui:FindFirstChild("_ListFrame (T_Ingredients)", true)
            if listMenu and listMenu.AbsoluteSize.Y > 0 then break end
        end

        if not listMenu or listMenu.AbsoluteSize.Y == 0 then return false end
        
        local targetFoodBtn = nil
        for i = 1, 50 do 
            if not isRunning or currentMacroId ~= myId then return false end
            targetFoodBtn = listMenu:FindFirstChild(selectedFood .. "_Button", true)
            if targetFoodBtn then break end; task.wait(0.1)
        end
        
        if targetFoodBtn then 
            local takeBtn = targetFoodBtn:FindFirstChild("Take")
            if takeBtn then
                ForceClick(takeBtn)
                local frame = listMenu:FindFirstChild("Frame")
                local masterEvent = frame and frame:FindFirstChild("Event")
                if masterEvent and masterEvent:IsA("BindableEvent") then pcall(function() masterEvent:Fire(targetFoodBtn) end) end
            end
        else
            Log("ERRO: Comida não achada.", Color3.fromRGB(255, 50, 50)); return false
        end
    end

    -- ==========================================
    -- VERIFICAÇÃO INTELIGENTE SE PEGOU A COMIDA
    -- ==========================================
    local hasFood = false
    local equippedBtn = nil
    for w = 1, 40 do -- Espera até 4 segundos pra comida aparecer nas mãos
        if not isRunning or currentMacroId ~= myId then return false end
        equippedBtn = PlayerGui:FindFirstChild("EquippedButton", true)
        if equippedBtn and equippedBtn.Visible then
            hasFood = true
            Log("Comida confirmada nas mãos!", Color3.fromRGB(50, 255, 50))
            break
        end
        task.wait(0.1)
    end

    if not hasFood then
        Log("ERRO: O item não foi parar na mão.", Color3.fromRGB(255, 50, 50))
        return false
    end

    -- ==========================================
    -- 2. ROTAS E ESTAÇÕES (O CÉREBRO)
    -- ==========================================
    local finished = false
    
    while isRunning and currentMacroId == myId and not finished do
        -- LÊ O RÓTULO PARA DECIDIR O DESTINO
        local targetStationName = "Basic Counter"
        local actionLbl = equippedBtn:FindFirstChild("ActionLabel")
        if actionLbl then
            local act = actionLbl.Text:lower()
            
            -- Se a palavra indicar fim (Place, Take Portion), termina!
            if table.find(finishedActions, act) then
                Log("Prato Finalizado Automaticamente!", Color3.fromRGB(50, 255, 50))
                finished = true
                break
            end
            
            Log("GPS: Precisamos " .. act, Color3.fromRGB(150, 200, 255))
            
            -- Define a estação pelo texto
            if string.find(act, "fry") or string.find(act, "boil") or string.find(act, "cook") or string.find(act, "bake") or string.find(act, "fritar") or string.find(act, "ferver") or string.find(act, "cozinhar") or string.find(act, "assar") then
                targetStationName = "Basic Stove"
            else
                targetStationName = "Basic Counter"
            end
        end

        local station = nil; local sDist = math.huge
        for _, item in pairs(workspace:WaitForChild("Plots"):GetDescendants()) do
            if item.Name == targetStationName then
                local d = (hrp.Position - item:GetPivot().Position).Magnitude
                if d < sDist then sDist = d; station = item end
            end
        end
        
        if station then
            WalkToTarget(hrp, hum, station, -3.5)
            task.wait(0.5); PressE(); task.wait(1)
            
            -- Tratamento de Erro do Jogo (Fallback)
            local msgBox = PlayerGui:FindFirstChild("MessageBox", true)
            if msgBox and msgBox.Visible then
                ForceClick(msgBox:FindFirstChild("ButtonFrame"):FindFirstChildWhichIsA("GuiButton", true))
                Log("Erro de estação contornado.", Color3.fromRGB(255, 200, 100))
                -- Deixa o GPS corrigir na próxima volta do loop
                continue
            end
            
            -- VERIFICA SE ESTÁ SUJO
            local interact = PlayerGui:FindFirstChild("_interactUI")
            if interact then
                for _, el in pairs(interact:GetDescendants()) do
                    if el:IsA("TextLabel") and (el.Text:lower() == "clean" or el.Text:lower() == "limpar") then
                        Log("Estação suja! Limpando...", Color3.fromRGB(255, 150, 50))
                        ForceClick(el.Parent); task.wait(9)
                        Log("Limpo! Recomeçando...", Color3.fromRGB(150, 255, 150))
                        return true
                    end
                end
            end
            
            -- ==========================================
            -- MINIGAME
            -- ==========================================
            local ticks = 0
            local maxRecipeTicks = 1200 
            local recipeTickCount = 0

            while recipeTickCount < maxRecipeTicks do
                if not isRunning or currentMacroId ~= myId then return false end
                local acted = false
                
                -- A) TELA CENTRAL DE LETRAS
                local floating = PlayerGui:FindFirstChild("FloatingGui")
                if floating then
                    for _, btn in pairs(floating:GetDescendants()) do
                        if btn.Name == "DefaultButton" and btn:IsA("GuiButton") and btn.Visible then
                            local letter = nil
                            for _, c in pairs(btn:GetDescendants()) do
                                local match = string.match(c.Text, "^%s*([A-Za-z])%s*$")
                                if c:IsA("TextLabel") and match then letter = string.upper(match) break end
                            end
                            
                            if letter and letter ~= "E" then
                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[letter], false, game)
                                task.wait(0.05); VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[letter], false, game)
                            else 
                                ForceClick(btn) 
                            end
                            acted = true
                        end
                    end
                end
                
                -- B) O BOTÃO AZUL (Que você descobriu!)
                if equippedBtn and equippedBtn.Visible then
                    local currentActionLbl = equippedBtn:FindFirstChild("ActionLabel")
                    if currentActionLbl then
                        local currentAction = currentActionLbl.Text:lower()
                        
                        -- Se o botão azul disser "Place" ou "Take", o prato acabou! Quebra o minigame.
                        if table.find(finishedActions, currentAction) then
                            finished = true
                            break
                        end
                        
                        if table.find(validActions, currentAction) then
                            ForceClick(equippedBtn)
                            acted = true
                        end
                    end
                end
                
                -- C) MÃOZINHAS AZUIS FLUTUANTES (Backup)
                local interactUI = PlayerGui:FindFirstChild("_interactUI")
                if interactUI and not acted then
                    for _, el in pairs(interactUI:GetDescendants()) do
                        if el:IsA("TextLabel") and table.find(validActions, el.Text:lower()) then
                            ForceClick(el.Parent)
                            acted = true
                            break
                        end
                    end
                end
                
                -- CONTROLE DE OCIOSIDADE (15s limite)
                if acted then
                    ticks = 0; task.wait(0.4)
                else
                    ticks = ticks + 1
                    if ticks > 150 then 
                        Log("Sem botões por 15s. Avançando.", Color3.fromRGB(50, 255, 50))
                        break -- Quebra o minigame, o loop principal vai ler a Label de novo pra saber pra onde ir
                    end
                end
                
                -- Se a Label mandou finalizar (do check B lá em cima)
                if finished then break end
                
                recipeTickCount = recipeTickCount + 1
                task.wait(0.1)
            end
        end
    end
    return true
end

-- === COMANDOS DO HUB ===
function _G.BloxburgChef.Start(foodName)
    if isRunning then return end
    selectedFood = foodName or "Hot Dogs"
    isRunning = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = 16 end 
    
    Log("GPS Culinário e Botão Azul Ativos", Color3.fromRGB(100, 200, 255))
    Log("=== FARM INICIADO: " .. selectedFood .. " ===", Color3.fromRGB(50, 255, 50))
    
    task.spawn(function()
        local hrp = char and char:WaitForChild("HumanoidRootPart")
        while isRunning and currentMacroId == myId do
            RunFarmCycle(hrp, hum, myId)
            task.wait(1)
        end
    end)
end

function _G.BloxburgChef.Stop()
    isRunning = false
    currentMacroId = currentMacroId + 1
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = 16; hum.JumpPower = 50 end
    Camera.CameraType = Enum.CameraType.Custom
    
    Log("=== FARM PARADO ===", Color3.fromRGB(255, 100, 100))
end
