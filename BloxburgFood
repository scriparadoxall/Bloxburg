                    -- 3. Clica na comida selecionada
                    if listMenu then
                        -- Adiciona um pequeno atraso para a animação de "abertura" do menu terminar
                        task.wait(0.4) 
                        
                        local foodBtn = listMenu:FindFirstChild(selectedFood .. "_Button", true)
                        
                        -- Fallback: Se não achar pelo nome exato do botão, procura lendo os textos
                        if not foodBtn then
                            for _, v in pairs(listMenu:GetDescendants()) do
                                if v:IsA("TextLabel") and string.find(string.lower(v.Text), string.lower(selectedFood)) then
                                    foodBtn = v.Parent
                                    break
                                end
                            end
                        end

                        if foodBtn then
                            Log("Pegando ingrediente: " .. selectedFood, Color3.fromRGB(200, 200, 255))
                            
                            -- Clica no botão principal
                            ForceClick(foodBtn)
                            
                            -- Procura e clica em todos os sub-botões internos (comum na UI do Bloxburg)
                            for _, child in pairs(foodBtn:GetDescendants()) do
                                if child:IsA("GuiButton") or child.Name == "Take" or child.Name == "Pegar" then
                                    ForceClick(child)
                                end
                            end

                            -- Dispara o evento interno como última garantia
                            local ev = listMenu:FindFirstChild("Frame") and listMenu.Frame:FindFirstChild("Event")
                            if ev then pcall(function() ev:Fire(foodBtn) end) end
                            
                        else
                            Log("Ingrediente '" .. selectedFood .. "' não encontrado na lista. Nome errado?", Color3.fromRGB(255, 100, 100))
                            task.wait(2)
                        end
                    end
