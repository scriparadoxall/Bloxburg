_G.Music = _G.Music or {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local isFarmingMusic = false
local currentMacroId = 0

-- Lista com os instrumentos
local InstrumentObjects = {
    "Toy Maracas", 
    "Toy Tambourine", 
    "Electric Guitar", 
    "Rockstar Guitar", 
    "Modern Guitar", 
    "Acoustic Guitar"
}

-- Lista de assentos
local SeatObjects = {"Sofa", "Chair", "Stool", "Bench"}

local function CarregarModulo(nomeExato)
    local url = "https://raw.githubusercontent.com/scriparadoxall/Bloxburg/main/" .. nomeExato
    local s, r = pcall(function() return loadstring(game:HttpGet(url))() end)
    return s and r or nil
end

-- MUDANÇA 1: Pega apenas UM instrumento (o mais próximo) e armazena
local instrumentoSelecionado = nil
local instrumentoNome = nil

local function GetTarget(list, especifico)
    local p = workspace.Plots:FindFirstChild("Plot_" .. Players.LocalPlayer.Name)
    local folder = p and p:FindFirstChild("House") and p.House:FindFirstChild("Objects")
    if not folder then return nil end

    local char = Players.LocalPlayer.Character
    local humRootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not humRootPart then return nil end

    local found = {}
    for _, obj in ipairs(folder:GetChildren()) do
        for _, name in ipairs(list) do
            if string.find(string.lower(obj.Name), string.lower(name)) then 
                table.insert(found, obj) 
                break 
            end
        end
    end

    if #found == 0 then return nil end

    -- Se especifico, retorna exatamente aquele objeto
    if especifico then
        for _, obj in ipairs(found) do
            if obj.Name == especifico then
                local part = obj:FindFirstChild("Seat", true) or obj:FindFirstChild("Door1", true) or obj
                return part, obj.Name
            end
        end
    end

    -- Caso contrário, pega o mais próximo
    local chosen = nil
    local menorDist = math.huge
    
    for _, obj in ipairs(found) do
        local objPos = obj:IsA("BasePart") and obj.Position or (obj:FindFirstChildWhichIsA("BasePart") and obj:FindFirstChildWhichIsA("BasePart").Position or nil)
        if objPos then
            local dist = (humRootPart.Position - objPos).Magnitude
            if dist < menorDist then
                menorDist = dist
                chosen = obj
            end
        end
    end

    if chosen then
        local part = chosen:FindFirstChild("Seat", true) or chosen:FindFirstChild("Door1", true) or chosen
        return part, chosen.Name
    end
    
    return nil
end

-- Função de verificação robusta (Caminho que você passou)
local function CheckHand()
    local ok, res = pcall(function()
        local label = game:GetService("Players").LocalPlayer.PlayerGui.HUDGui.Hotbar.LayoutContainer.LeftButtonContainer.EquippedContainer.ActionLabel
        if label and label.Parent.Visible and label.Text ~= "" then
            return string.lower(label.Text)
        end
        return "" 
    end)
    return ok and res or ""
end

local function Espera_ApertaE_Reseta(validWords)
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
    end)
    task.wait(0.5) 
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local timeout = tick() + 2.5 
    local achouUI = false
    
    while tick() < timeout do
        local interactUI = playerGui:FindFirstChild("_interactUI")
        if interactUI then
            local indicator = interactUI:FindFirstChild("InteractIndicator")
            if indicator and indicator.Visible then
                local textLabel = indicator:FindFirstChild("TextLabel")
                if textLabel then
                    local txt = string.lower(textLabel.Text)
                    for _, word in ipairs(validWords) do
                        if string.find(txt, word) then
                            achouUI = true
                            break
                        end
                    end
                end
            end
        end
        if achouUI then break end
        task.wait(0.1)
    end
    
    if achouUI then
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.2)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(1)
    end
    return achouUI
end

-- Simula clique do mouse para tocar
local function ClacarParaTocar()
    local mouse = Players.LocalPlayer:GetMouse()
    
    pcall(function()
        mouse.Button1Down:Fire()
    end)
    
    task.wait(0.08)
    
    pcall(function()
        mouse.Button1Up:Fire()
    end)
end

function _G.Music.Start()
    if isFarmingMusic then return end
    isFarmingMusic = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId

    task.spawn(function()
        while isFarmingMusic and currentMacroId == myId do
            local char = Players.LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if not hum then task.wait(1) continue end

            local handText = CheckHand()
            
            -- MUDANÇA 2: Verifica se está tocando (tem "stop" ou "parar" na mão)
            local isPlaying = string.find(handText, "stop") or string.find(handText, "parar")

            if isPlaying then
                -- ESTADO: TOCANDO. Aguarda até sumir o "stop"
                task.wait(2)
                
            else
                -- MUDANÇA 3: Se NÃO tem instrumento, procura UM e armazena
                if not instrumentoSelecionado then
                    if hum.Sit then
                        hum.Jump = true 
                        task.wait(1)
                    else
                        instrumentoSelecionado = GetTarget(InstrumentObjects)
                        if instrumentoSelecionado then
                            instrumentoNome = (instrumentoSelecionado.Parent and instrumentoSelecionado.Parent.Name) or instrumentoSelecionado.Name
                            print("🎸 Instrumento selecionado: " .. instrumentoNome)
                            
                            local door = CarregarModulo("smart_door.lua")
                            if door then door.IrPara(instrumentoSelecionado) end
                            
                            local cam = CarregarModulo("smart_cam")
                            if cam and cam.OlharPara(instrumentoSelecionado) then
                                Espera_ApertaE_Reseta({"take", "equip", "play", "pegar", "tocar", "use"})
                            end
                        else
                            task.wait(1)
                        end
                    end
                    
                else
                    -- MUDANÇA 4: Já tem instrumento. Agora joga dado para decidir ação
                    local isHolding = string.find(handText, "play") or string.find(handText, "tocar") or string.find(handText, "use") or string.find(handText, "usar")
                    
                    if isHolding then
                        -- Pegou o instrumento. Joga dado UMA VEZ
                        local dado = math.random(1, 2)
                        print("🎲 Dado: " .. dado)
                        
                        if dado == 1 then
                            -- DADO 1: DE PÉ - Apenas clica para tocar
                            print("🎵 Ação 1: DE PÉ - Tocando música")
                            ClacarParaTocar()
                            task.wait(3)
                            
                        else
                            -- DADO 2: SENTADO - Procura uma cadeira
                            print("🪑 Ação 2: SENTADO - Procurando cadeira")
                            local seatPart = GetTarget(SeatObjects)
                            
                            if seatPart then
                                local door = CarregarModulo("smart_door.lua") 
                                if door then door.IrPara(seatPart) end
                                
                                local cam = CarregarModulo("smart_cam")
                                if cam and cam.OlharPara(seatPart) then
                                    Espera_ApertaE_Reseta({"sit", "use", "sentar", "usar"})
                                end
                                
                                task.wait(1)
                                -- Agora toca
                                ClacarParaTocar()
                                task.wait(3)
                            else
                                -- Não achou cadeira, toca em pé
                                print("⚠️ Cadeira não encontrada, tocando em pé")
                                ClacarParaTocar()
                                task.wait(3)
                            end
                        end
                        
                        -- MUDANÇA 5: Aguarda até a música acabar (até sumir o "stop")
                        local timeout = tick() + 30 -- Máximo 30 segundos
                        while isFarmingMusic and currentMacroId == myId and tick() < timeout do
                            local handCheck = CheckHand()
                            if string.find(handCheck, "stop") or string.find(handCheck, "parar") then
                                -- Ainda tocando
                                task.wait(2)
                            else
                                -- Acabou! Reseta para buscar novo instrumento
                                print("✅ Música acabou!")
                                instrumentoSelecionado = nil
                                instrumentoNome = nil
                                break
                            end
                        end
                    else
                        -- Ainda não pegou o instrumento
                        task.wait(0.5)
                    end
                end
            end
            
            task.wait(0.5)
        end
    end)
end

function _G.Music.Stop()
    isFarmingMusic = false
    currentMacroId = currentMacroId + 1
    instrumentoSelecionado = nil
    instrumentoNome = nil
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
    end)
end

return _G.Music