_G.Music = _G.Music or {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local isFarmingMusic = false
local currentMacroId = 0

-- Lista com os instrumentos
local InstrumentObjects = {
    "Toy Maracas", 
    "Toy Tambourine", 
    "Electric Guitar", 
    "Rockstar Guitar", 
    "Modern Guitar", 
    "Acoustic Guitar"
}

-- Lista de assentos
local SeatObjects = {"Sofa", "Chair", "Stool", "Bench"}

local function CarregarModulo(nomeExato)
    local url = "https://raw.githubusercontent.com/scriparadoxall/Bloxburg/main/" .. nomeExato
    local s, r = pcall(function() return loadstring(game:HttpGet(url))() end)
    return s and r or nil
end

-- Armazena o estado do dado
local acaoDado = nil 

local function GetTarget(list)
    local p = workspace.Plots:FindFirstChild("Plot_" .. Players.LocalPlayer.Name)
    local folder = p and p:FindFirstChild("House") and p.House:FindFirstChild("Objects")
    if not folder then return nil end

    local found = {}
    for _, obj in ipairs(folder:GetChildren()) do
        for _, name in ipairs(list) do
            if string.find(string.lower(obj.Name), string.lower(name)) then 
                table.insert(found, obj) 
                break 
            end
        end
    end

    if #found == 0 then return nil end

    print("🎲 Instrumentos encontrados na casa: " .. #found)
    
    -- Garante que o sorteio seja sempre diferente
    math.randomseed(tick())
    local chosen = found[math.random(1, #found)]

    if chosen then
        local part = chosen:FindFirstChild("Seat", true) or chosen:FindFirstChild("Door1", true) or chosen
        return part, chosen.Name
    end
    
    return nil
end

-- NOVO CAMINHO: Verifica se tem instrumento na mão (olha o ActionLabel)
local function TemInstrumentoNaMao()
    local ok, res = pcall(function()
        -- Usando o caminho exato que você mandou (sem LayoutContainer)
        local label = game:GetService("Players").LocalPlayer.PlayerGui.HUDGui.Hotbar.EquippedContainer.ActionLabel
        
        -- Converte tudo para minúsculo para não ter problema com maiúsculas/minúsculas
        if label and label.Parent.Visible and label.Text ~= "" then
            return string.lower(label.Text)
        end
        return "" 
    end)
    return ok and res or ""
end

local function Espera_ApertaE_Reseta(validWords)
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
    end)
    task.wait(0.5) 
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local timeout = tick() + 2.5 
    local achouUI = false
    
    while tick() < timeout do
        local interactUI = playerGui:FindFirstChild("_interactUI")
        if interactUI then
            local indicator = interactUI:FindFirstChild("InteractIndicator")
            if indicator and indicator.Visible then
                local textLabel = indicator:FindFirstChild("TextLabel")
                if textLabel then
                    local txt = string.lower(textLabel.Text)
                    for _, word in ipairs(validWords) do
                        if string.find(txt, word) then
                            achouUI = true
                            break
                        end
                    end
                end
            end
        end
        if achouUI then break end
        task.wait(0.1)
    end
    
    if achouUI then
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.2)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(1)
    end
    return achouUI
end

function _G.Music.Start()
    if isFarmingMusic then return end
    isFarmingMusic = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId

    task.spawn(function()
        while isFarmingMusic and currentMacroId == myId do
            local char = Players.LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if not hum then task.wait(1) continue end

            local handText = TemInstrumentoNaMao()
            
            -- ESTADOS CORRIGIDOS ("pause" = tocando, "play" = segurando)
            local estaTocando = string.find(handText, "pause") or string.find(handText, "pausar")
            local estaSegurando = string.find(handText, "play") or string.find(handText, "tocar") or string.find(handText, "use") or string.find(handText, "usar")

            if estaTocando then
                -- ESTADO: TOCANDO - Fica em modo de espera silenciosa
                print("🎵 Tocando... Botão mostra 'Pause'. Verificando a cada 5s.")
                task.wait(5) 
                
            elseif estaSegurando then
                -- ESTADO: JÁ PEGOU O INSTRUMENTO (Botão mostra 'Play')
                print("🎸 Instrumento na mão! Decidindo posição...")
                
                -- PROBABILIDADE 2 EM 1 (1 ou 2 = Sentar, 3 = Pé)
                if not acaoDado then
                    math.randomseed(tick())
                    acaoDado = math.random(1, 3)
                    print("🎲 Dado sorteado: " .. acaoDado .. " (1 e 2 senta, 3 fica em pé)")
                end
                
                if acaoDado == 3 then
                    -- AÇÃO: DE PÉ
                    print("🎵 Escolhido: Tocar de pé.")
                    task.spawn(function() CarregarModulo("smart_click") end)
                    task.wait(3)
                else
                    -- AÇÃO: SENTADO
                    if not hum.Sit then
                        print("🪑 Escolhido: Sentar. Procurando assento...")
                        local seatPart = GetTarget(SeatObjects)
                        
                        if seatPart then
                            local door = CarregarModulo("smart_door.lua") 
                            if door then door.IrPara(seatPart) end
                            
                            local cam = CarregarModulo("smart_cam")
                            if cam and cam.OlharPara(seatPart) then
                                Espera_ApertaE_Reseta({"sit", "use", "sentar", "usar"})
                            end
                            task.wait(2) 
                        else
                            print("⚠️ Nenhum sofá/cadeira, tocando em pé.")
                            task.spawn(function() CarregarModulo("smart_click") end)
                            task.wait(3)
                        end
                    else
                        -- Já sentou, agora toca
                        task.spawn(function() CarregarModulo("smart_click") end)
                        task.wait(3)
                    end
                end
                
            else
                -- ESTADO: MÃOS VAZIAS (Texto sumiu ou não é nem Play nem Pause)
                acaoDado = nil -- Reseta a decisão para o próximo ciclo
                
                if hum.Sit then
                    hum.Jump = true 
                    task.wait(1)
                else
                    print("🔍 Buscando instrumento aleatório...")
                    local instrumentoPart = GetTarget(InstrumentObjects)
                    
                    if instrumentoPart then
                        print("🎸 Sorteado e indo até o instrumento!")
                        
                        local door = CarregarModulo("smart_door.lua")
                        if door then door.IrPara(instrumentoPart) end
                        
                        local cam = CarregarModulo("smart_cam")
                        if cam and cam.OlharPara(instrumentoPart) then
                            Espera_ApertaE_Reseta({"take", "equip", "play", "pegar", "tocar", "use", "usar"})
                        end
                    else
                        print("⏳ Casa vazia? Aguardando instrumentos...")
                        task.wait(5)
                    end
                end
            end
            
            task.wait(0.5)
        end
    end)
end

function _G.Music.Stop()
    isFarmingMusic = false
    currentMacroId = currentMacroId + 1
    acaoDado = nil
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
    end)
end

return _G.Music
