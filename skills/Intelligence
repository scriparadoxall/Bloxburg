_G.Intelligence = {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local isFarmingIntel = false
local currentMacroId = 0

---------------------------------------------------------
-- GERENCIADOR DE MÓDULOS (Cache para não lagar)
---------------------------------------------------------
local ModulosCarregados = {}

local function CarregarModulo(nomeExato)
    if ModulosCarregados[nomeExato] then return ModulosCarregados[nomeExato] end

    local url = "https://raw.githubusercontent.com/scriparadoxall/Bloxburg/main/" .. nomeExato
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)

    if success and result then
        ModulosCarregados[nomeExato] = result
        return result
    end
    return nil
end

---------------------------------------------------------
-- LISTAS DE ALVOS (Camas removidas)
---------------------------------------------------------
local BookObjects = {"Simplicity Bookcase", "Large Simplicity Bookcase", "Simplicity Dresser", "Simplicity Table", "Ordered Plain Books", "Book"}
local SeatObjects = {"Simple Sofa", "MightyFlush Toilet", "Chair", "Sofa", "Stool", "Bench"}

---------------------------------------------------------
-- FUNÇÕES DE DEBUG VISUAL
---------------------------------------------------------
local function LimparMarcacoes()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "IntelDebugHighlight" then 
            obj:Destroy() 
        end
    end
end

local function DestacarAlvo(alvo)
    LimparMarcacoes()
    if not _G.MostrarObjetosIntel or not alvo then return end

    local modelToHighlight = alvo
    if not modelToHighlight:IsA("Model") and not modelToHighlight:IsA("BasePart") then
        modelToHighlight = alvo:FindFirstAncestorWhichIsA("Model") or alvo.Parent
    end

    if modelToHighlight and (modelToHighlight:IsA("Model") or modelToHighlight:IsA("BasePart")) then
        local hl = Instance.new("Highlight")
        hl.Name = "IntelDebugHighlight"
        hl.FillColor = Color3.fromRGB(0, 255, 100) -- VERDE
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.fromRGB(0, 200, 50)
        hl.Parent = modelToHighlight
    end
end

---------------------------------------------------------
-- FUNÇÕES AUXILIARES, CÂMERA E UI
---------------------------------------------------------

local function GetPlayerHouse()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end

    local myPlotName = "Plot_" .. Players.LocalPlayer.Name
    local myPlot = plots:FindFirstChild(myPlotName)
    if myPlot then return myPlot:FindFirstChild("House") end

    for _, plot in ipairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner then
            if typeof(owner.Value) == "Instance" and owner.Value == Players.LocalPlayer then
                return plot:FindFirstChild("House")
            elseif type(owner.Value) == "string" and owner.Value == Players.LocalPlayer.Name then
                return plot:FindFirstChild("House")
            end
        end
    end
    return nil
end

local function GetRandomObject(objectList)
    local house = GetPlayerHouse()
    if not house then return nil, "Casa não encontrada" end

    local objectsFolder = house:FindFirstChild("Objects")
    if not objectsFolder then return nil, "Pasta 'Objects' vazia" end

    local availableObjects = {}
    for _, obj in ipairs(objectsFolder:GetChildren()) do
        for _, objName in ipairs(objectList) do
            if string.find(string.lower(obj.Name), string.lower(objName)) then
                table.insert(availableObjects, obj)
                break
            end
        end
    end

    if #availableObjects > 0 then
        local randomIndex = math.random(1, #availableObjects)
        local chosenObj = availableObjects[randomIndex]
        
        local targetPart = chosenObj
        if chosenObj:FindFirstChild("ObjectModel") then
            if chosenObj.ObjectModel:FindFirstChild("Books") then targetPart = chosenObj.ObjectModel.Books
            elseif chosenObj.ObjectModel:FindFirstChild("Door1") then targetPart = chosenObj.ObjectModel.Door1 end
        elseif chosenObj:FindFirstChild("ItemHolder") then
            targetPart = chosenObj.ItemHolder
        end
        
        return targetPart, "Sucesso", chosenObj.Name
    end
    return nil, "Móvel não achado"
end

local function SafeClick(element)
    if not element then return false end
    local success = false
    pcall(function()
        if getconnections then
            if element.MouseButton1Click then 
                for _, conn in pairs(getconnections(element.MouseButton1Click)) do conn:Fire(); success = true end 
            end
            if not success and element.Activated then 
                for _, conn in pairs(getconnections(element.Activated)) do conn:Fire(); success = true end 
            end
            if not success and element.MouseButton1Down then
                 for _, conn in pairs(getconnections(element.MouseButton1Down)) do conn:Fire() end 
                 for _, conn in pairs(getconnections(element.MouseButton1Up)) do conn:Fire() end 
                 success = true
            end
        end
    end)
    return success
end

local function InteractOnce(validWords)
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local interactUI = playerGui:FindFirstChild("_interactUI")

    if interactUI then
        local indicator = interactUI:FindFirstChild("InteractIndicator")
        if indicator and indicator.Visible then
            local textLabel = indicator:FindFirstChild("TextLabel")
            if textLabel then
                local currentText = string.lower(textLabel.Text)
                for _, word in ipairs(validWords) do
                    if string.find(currentText, string.lower(word)) then
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                        task.wait(0.05)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                        return true
                    end
                end
            end
        end
    end
    return false
end

local function CheckHandAction()
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local hudGui = playerGui:FindFirstChild("HUDGui")
    if hudGui then
        local hotbar = hudGui:FindFirstChild("Hotbar")
        if hotbar then
            local layout = hotbar:FindFirstChild("LayoutContainer")
            if layout then
                local leftBtn = layout:FindFirstChild("LeftButtonContainer")
                if leftBtn then
                    local equippedContainer = leftBtn:FindFirstChild("EquippedContainer")
                    if equippedContainer and equippedContainer.Visible then
                        local actionLabel = equippedContainer:FindFirstChild("ActionLabel")
                        if actionLabel and actionLabel.Text ~= "" then
                            return string.lower(actionLabel.Text), equippedContainer
                        end
                    end
                end
            end
        end
    end
    return nil, nil
end

---------------------------------------------------------
-- LOOP PRINCIPAL
---------------------------------------------------------
function _G.Intelligence.Start()
    if isFarmingIntel then return end
    isFarmingIntel = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId

    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência Iniciado!", Color3.fromRGB(150, 150, 255)) end

    task.spawn(function()
        while isFarmingIntel and currentMacroId == myId do
            local char = Players.LocalPlayer.Character
            if not char or not char:FindFirstChild("Humanoid") then task.wait(2) continue end
            local hum = char.Humanoid

            -- PASSO 1: VERIFICA O QUE TEM NA MÃO
            local handAction, handButton = CheckHandAction()
            local temLivroNaMao = false

            if handAction and (string.find(handAction, "use") or string.find(handAction, "read") or string.find(handAction, "usar") or string.find(handAction, "ler")) then
                temLivroNaMao = true
            end

            -- PASSO 2: PEGAR O LIVRO
            if not temLivroNaMao and not hum.Sit then
                local randomBook, erroBook, bookName = GetRandomObject(BookObjects)
                
                if randomBook then
                    DestacarAlvo(randomBook)
                    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Buscando livro: " .. tostring(bookName), Color3.fromRGB(200, 200, 200)) end
                    
                    local doorSystem = CarregarModulo("smart_door.lua")
                    if doorSystem and doorSystem.IrPara then 
                        doorSystem.IrPara(randomBook) 
                    end
                    
                    local camSystem = CarregarModulo("smart_cam")
                    if camSystem and camSystem.OlharPara then
                        camSystem.OlharPara(randomBook)
                    end
                    
                    InteractOnce({"take", "read", "book", "ler", "pegar"})
                    
                    -- DEVOLVE A CÂMERA IMEDIATAMENTE
                    if camSystem and camSystem.Reset then camSystem.Reset() end
                    
                    -- Espera o livro ir para a mão
                    task.wait(2)
                else
                    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Sem estantes. Pausando.", Color3.fromRGB(255, 100, 100)) end
                    task.wait(5)
                end

            -- PASSO 3: ESTÁ COM O LIVRO NA MÃO E EM PÉ
            elseif temLivroNaMao then
                if not hum.Sit then
                    local randomSeat, erroSeat, seatName = GetRandomObject(SeatObjects)
                    
                    if randomSeat then
                        DestacarAlvo(randomSeat)
                        if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Indo sentar em: " .. tostring(seatName), Color3.fromRGB(200, 200, 200)) end
                        
                        local doorSystem = CarregarModulo("smart_door.lua")
                        if doorSystem and doorSystem.IrPara then 
                            doorSystem.IrPara(randomSeat) 
                        end
                        
                        local camSystem = CarregarModulo("smart_cam")
                        if camSystem and camSystem.OlharPara then
                            camSystem.OlharPara(randomSeat)
                        end
                        
                        InteractOnce({"sit", "use", "sentar", "usar"})
                        
                        -- DEVOLVE A CÂMERA IMEDIATAMENTE
                        if camSystem and camSystem.Reset then camSystem.Reset() end
                        
                        task.wait(2)
                    else
                        if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Lendo de pé!", Color3.fromRGB(255, 200, 100)) end
                        if handButton then SafeClick(handButton) end
                        task.wait(15)
                    end
                
                -- PASSO 4: LENDO (Já sentado ou lendo em pé animado)
                else
                    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Lendo tranquilo...", Color3.fromRGB(100, 255, 100)) end
                    
                    for i=1, 15 do
                        if not isFarmingIntel or currentMacroId ~= myId or hum.Sit == false then break end
                        task.wait(1)
                    end
                    
                    hum.Jump = true 
                    task.wait(1)
                    LimparMarcacoes() 
                end
            end
            
            task.wait(0.5)
        end
    end)
end

function _G.Intelligence.Stop()
    isFarmingIntel = false
    currentMacroId = currentMacroId + 1
    LimparMarcacoes()
    
    local doorSystem = CarregarModulo("smart_door.lua")
    if doorSystem and type(doorSystem.Cancelar) == "function" then
        doorSystem.Cancelar()
    end
    
    local camSystem = CarregarModulo("smart_cam")
    if camSystem and camSystem.Reset then
        camSystem.Reset()
    end

    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência parado.", Color3.fromRGB(255, 100, 100)) end
end

return _G.Intelligence
