_G.Intelligence = {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local VirtualUser = game:GetService("VirtualUser")
local isFarmingIntel = false

---------------------------------------------------------
-- CONFIGURAÇÕES DE OBJETOS
---------------------------------------------------------
local BookObjects = {
    "Simplicity Bookcase",
    "Large Simplicity Bookcase",
    "Simplicity Dresser",
    "Simplicity Table",
    "Ordered Plain Books",
    "Book"
}

local SeatObjects = {
    "Simple Sofa",
    "MightyFlush Toilet",
    "Chair",
    "Sofa",
    "Bed",
    "Stool"
}

---------------------------------------------------------
-- FUNÇÕES AUXILIARES
---------------------------------------------------------

-- Encontra a casa (Agora usa exatamente o padrão Plot_SeuNick)
local function GetPlayerHouse()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end

    -- Busca direta e garantida (Ex: Plot_drivingnsane)
    local myPlotName = "Plot_" .. Players.LocalPlayer.Name
    local myPlot = plots:FindFirstChild(myPlotName)
    
    if myPlot then
        return myPlot:FindFirstChild("House")
    end

    -- Plano B caso o nick mude ou algo do tipo
    for _, plot in ipairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner then
            if typeof(owner.Value) == "Instance" and owner.Value == Players.LocalPlayer then
                return plot:FindFirstChild("House")
            elseif type(owner.Value) == "string" and owner.Value == Players.LocalPlayer.Name then
                return plot:FindFirstChild("House")
            end
        end
    end
    return nil
end

-- Pega um objeto aleatório
local function GetRandomObject(objectList)
    local house = GetPlayerHouse()
    if not house then return nil, "Casa (Plot_".. Players.LocalPlayer.Name ..") não encontrada no mapa." end

    local objectsFolder = house:FindFirstChild("Objects")
    if not objectsFolder then return nil, "Pasta 'Objects' não encontrada na sua casa." end

    local availableObjects = {}
    
    for _, obj in ipairs(objectsFolder:GetChildren()) do
        for _, objName in ipairs(objectList) do
            if string.find(string.lower(obj.Name), string.lower(objName)) then
                table.insert(availableObjects, obj)
                break
            end
        end
    end

    if #availableObjects > 0 then
        local randomIndex = math.random(1, #availableObjects)
        local chosenObj = availableObjects[randomIndex]
        
        -- Se o objeto tiver partes internas interativas (como o .Books que você mandou), pega elas como alvo para mirar melhor
        local targetPart = chosenObj
        if chosenObj:FindFirstChild("ObjectModel") then
            if chosenObj.ObjectModel:FindFirstChild("Books") then
                targetPart = chosenObj.ObjectModel.Books
            elseif chosenObj.ObjectModel:FindFirstChild("Door1") then
                targetPart = chosenObj.ObjectModel.Door1
            end
        elseif chosenObj:FindFirstChild("ItemHolder") then
            targetPart = chosenObj.ItemHolder
        end
        
        return targetPart, "Sucesso", chosenObj.Name
    end

    return nil, "Nenhum móvel compatível com a lista foi achado."
end

-- Verifica a UI e aperta "E"
local function InteractWithUI(validWords)
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local interactUI = playerGui:FindFirstChild("_interactUI")

    if interactUI then
        local indicator = interactUI:FindFirstChild("InteractIndicator")
        if indicator and indicator.Visible then
            local textLabel = indicator:FindFirstChild("TextLabel")
            if textLabel then
                local currentText = string.lower(textLabel.Text)

                for _, word in ipairs(validWords) do
                    if string.find(currentText, string.lower(word)) then
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                        task.wait(0.1)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                        return true
                    end
                end
            end
        end
    end
    return false
end

---------------------------------------------------------
-- LOOP PRINCIPAL DO FARM
---------------------------------------------------------

function _G.Intelligence.Start()
    if isFarmingIntel then return end
    isFarmingIntel = true

    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência Iniciado!", Color3.fromRGB(150, 150, 255)) end

    task.spawn(function()
        while isFarmingIntel do
            -------------------------------------------------
            -- PASSO 1: Achar e pegar um Livro Aleatório
            -------------------------------------------------
            local randomBookTarget, erroMotivo, bookName = GetRandomObject(BookObjects)

            if randomBookTarget then
                if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Indo até: " .. tostring(bookName), Color3.fromRGB(200, 200, 200)) end

                if _G.SmartDoor and _G.SmartDoor.IrPara then
                    _G.SmartDoor.IrPara(randomBookTarget)
                end

                task.wait(1.5)

                local hasTakenBook = InteractWithUI({"take", "read", "book", "ler", "pegar"})

                if hasTakenBook then
                    task.wait(1.5)

                    -------------------------------------------------
                    -- PASSO 2: Achar Assento e Sentar
                    -------------------------------------------------
                    local randomSeatTarget, seatMotivo, seatName = GetRandomObject(SeatObjects)

                    if randomSeatTarget then
                        if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Buscando assento: " .. tostring(seatName), Color3.fromRGB(200, 200, 200)) end

                        if _G.SmartDoor and _G.SmartDoor.IrPara then
                            _G.SmartDoor.IrPara(randomSeatTarget)
                        end

                        task.wait(1.5)

                        local hasSat = InteractWithUI({"sit", "use", "sentar", "usar"})

                        if hasSat then
                            if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Lendo...", Color3.fromRGB(100, 255, 100)) end
                            task.wait(15) 
                        else
                            if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Chegou no assento mas a UI não apareceu.", Color3.fromRGB(255, 150, 100)) end
                            task.wait(2)
                        end
                    else
                        if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Assento não achado: " .. seatMotivo, Color3.fromRGB(255, 150, 100)) end
                        task.wait(3)
                    end
                else
                    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Chegou na estante, mas não deu para pegar o livro.", Color3.fromRGB(255, 150, 100)) end
                    task.wait(3)
                end
            else
                if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Erro: " .. erroMotivo, Color3.fromRGB(255, 100, 100)) end
                task.wait(5)
            end

            task.wait(1)
        end
    end)
end

function _G.Intelligence.Stop()
    isFarmingIntel = false
    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência parado.", Color3.fromRGB(255, 100, 100)) end
end

return _G.Intelligence
