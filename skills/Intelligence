_G.Intelligence = {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local isFarmingIntel = false
local currentMacroId = 0

local BookObjects = {"Bookcase", "Dresser", "Books", "Book"}
local SeatObjects = {"Sofa", "Toilet", "Chair", "Stool", "Bench"}

local function CarregarModulo(nomeExato)
    local url = "https://raw.githubusercontent.com/scriparadoxall/Bloxburg/main/" .. nomeExato
    local s, r = pcall(function() return loadstring(game:HttpGet(url))() end)
    return s and r or nil
end

local function GetTarget(list)
    local p = workspace.Plots:FindFirstChild("Plot_" .. Players.LocalPlayer.Name)
    local folder = p and p:FindFirstChild("House") and p.House:FindFirstChild("Objects")
    if not folder then return nil end
    
    local found = {}
    for _, obj in ipairs(folder:GetChildren()) do
        for _, name in ipairs(list) do
            if string.find(string.lower(obj.Name), string.lower(name)) then table.insert(found, obj) break end
        end
    end
    
    if #found > 0 then
        local chosen = found[math.random(1, #found)]
        local part = chosen:FindFirstChild("Books", true) or chosen:FindFirstChild("Seat", true) or chosen:FindFirstChild("Door1", true) or chosen
        return part, chosen.Name
    end
    return nil
end

local function CheckHand()
    local ok, res = pcall(function()
        local label = Players.LocalPlayer.PlayerGui.HUDGui.Hotbar.LayoutContainer.LeftButtonContainer.EquippedContainer.ActionLabel
        if label and label.Parent.Visible then
            return string.lower(label.Text)
        end
        return ""
    end)
    return ok and res or ""
end

local function ClicarBotaoEquipado()
    pcall(function()
        local container = Players.LocalPlayer.PlayerGui.HUDGui.Hotbar.LayoutContainer.LeftButtonContainer.EquippedContainer
        if container and container.Visible then
            local pos = container.AbsolutePosition
            local size = container.AbsoluteSize
            local inset = GuiService:GetGuiInset()
            local x = pos.X + (size.X / 2) + inset.X
            local y = pos.Y + (size.Y / 2) + inset.Y
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
            task.wait(0.1)
            VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
        end
    end)
end

local function Espera_ApertaE_Reseta(validWords)
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
    end)
    task.wait(0.5) 
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local timeout = tick() + 2.5 
    local achouUI = false
    while tick() < timeout do
        local interactUI = playerGui:FindFirstChild("_interactUI")
        if interactUI then
            local indicator = interactUI:FindFirstChild("InteractIndicator")
            if indicator and indicator.Visible then
                local textLabel = indicator:FindFirstChild("TextLabel")
                if textLabel then
                    local txt = string.lower(textLabel.Text)
                    for _, word in ipairs(validWords) do
                        if string.find(txt, word) then
                            achouUI = true
                            break
                        end
                    end
                end
            end
        end
        if achouUI then break end
        task.wait(0.1)
    end
    if achouUI then
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.2)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.5)
    end
    return achouUI
end

function _G.Intelligence.Start()
    if isFarmingIntel then return end
    isFarmingIntel = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId

    task.spawn(function()
        while isFarmingIntel and currentMacroId == myId do
            local char = Players.LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if not hum then task.wait(1) continue end

            local handText = CheckHand()
            local isHolding = string.find(handText, "use") or string.find(handText, "read") or string.find(handText, "ler") or string.find(handText, "equip")
            local isReading = string.find(handText, "stop") or string.find(handText, "parar")

            if isReading and hum.Sit then
                task.wait(15)
                hum.Jump = true 
                task.wait(1)
            elseif isHolding and hum.Sit then
                task.wait(0.3)
                ClicarBotaoEquipado()
                task.wait(1)
            elseif isHolding and not hum.Sit then
                local seatPart = GetTarget(SeatObjects)
                if seatPart then
                    local door = CarregarModulo("smart_door.lua")
                    if door then door.IrPara(seatPart) end
                    local cam = CarregarModulo("smart_cam")
                    if cam then 
                        local cameraPronta = cam.OlharPara(seatPart)
                        if cameraPronta then
                            Espera_ApertaE_Reseta({"sit", "use", "sentar", "usar"})
                        end
                    end
                end
            elseif not isHolding and not isReading and not hum.Sit then
                local bookPart = GetTarget(BookObjects)
                if bookPart then
                    local door = CarregarModulo("smart_door.lua")
                    if door then door.IrPara(bookPart) end
                    local cam = CarregarModulo("smart_cam")
                    if cam then 
                        local cameraPronta = cam.OlharPara(bookPart)
                        if cameraPronta then
                            Espera_ApertaE_Reseta({"take", "read", "book", "ler", "pegar"})
                        end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

function _G.Intelligence.Stop()
    isFarmingIntel = false
    currentMacroId = currentMacroId + 1
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
    end)
end

return _G.Intelligence
