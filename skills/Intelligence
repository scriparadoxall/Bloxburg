_G.Intelligence = {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local VirtualUser = game:GetService("VirtualUser")
local isFarmingIntel = false

---------------------------------------------------------
-- CONFIGURAÇÕES DE OBJETOS (Nomes Exatos)
---------------------------------------------------------
local BookObjects = {
    "Simplicity Bookcase",
    "Large Simplicity Bookcase",
    "Simplicity Dresser",
    "Simplicity Table",
    "Ordered Plain Books"
}

local SeatObjects = {
    "Simple Sofa",
    "MightyFlush Toilet"
}

---------------------------------------------------------
-- FUNÇÕES AUXILIARES
---------------------------------------------------------

-- Encontra a casa do jogador local automaticamente
local function GetPlayerHouse()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end

    for _, plot in ipairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner and owner.Value == Players.LocalPlayer then
            return plot:FindFirstChild("House")
        end
    end
    return nil
end

-- Pega um objeto aleatório da casa baseado nas nossas listas
local function GetRandomObject(objectList)
    local house = GetPlayerHouse()
    if not house then return nil end

    local objectsFolder = house:FindFirstChild("Objects")
    if not objectsFolder then return nil end

    -- Embaralha e tenta achar algum objeto válido da lista
    local availableObjects = {}
    for _, objName in ipairs(objectList) do
        local obj = objectsFolder:FindFirstChild(objName)
        if obj then
            table.insert(availableObjects, obj)
        end
    end

    if #availableObjects > 0 then
        local randomIndex = math.random(1, #availableObjects)
        return availableObjects[randomIndex]
    end

    return nil
end

-- Simula o clique do mouse em uma parte 3D
local function ClickOnPart(part)
    local camera = workspace.CurrentCamera
    local screenPoint, onScreen = camera:WorldToScreenPoint(part.Position)

    if onScreen then
        VirtualUser:Button1Down(Vector2.new(screenPoint.X, screenPoint.Y), camera.CFrame)
        task.wait(0.1)
        VirtualUser:Button1Up(Vector2.new(screenPoint.X, screenPoint.Y), camera.CFrame)
    end
end

-- Verifica a UI e aperta "E" se achar as palavras-chave
local function InteractWithUI(validWords)
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local interactUI = playerGui:FindFirstChild("_interactUI")

    if interactUI then
        local indicator = interactUI:FindFirstChild("InteractIndicator")
        if indicator then
            local textLabel = indicator:FindFirstChild("TextLabel")
            if textLabel then
                local currentText = string.lower(textLabel.Text)

                for _, word in ipairs(validWords) do
                    if string.find(currentText, string.lower(word)) then
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                        task.wait(0.1)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                        return true
                    end
                end
            end
        end
    end
    return false
end

---------------------------------------------------------
-- LOOP PRINCIPAL DO FARM
---------------------------------------------------------

function _G.Intelligence.Start()
    if isFarmingIntel then return end
    isFarmingIntel = true

    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência Iniciado!", Color3.fromRGB(150, 150, 255)) end

    task.spawn(function()
        while isFarmingIntel do
            -------------------------------------------------
            -- PASSO 1: Achar e pegar um Livro Aleatório
            -------------------------------------------------
            local randomBookTarget = GetRandomObject(BookObjects)

            if randomBookTarget then
                if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Indo até: " .. randomBookTarget.Name, Color3.fromRGB(200, 200, 200)) end

                -- Mandando o objeto final direto pro seu SmartDoor!
                if _G.SmartDoor and _G.SmartDoor.IrPara then
                    _G.SmartDoor.IrPara(randomBookTarget)
                end

                task.wait(1)

                -- Tenta apertar E se aparecer "Take", "Read" ou "Book"
                local hasTakenBook = InteractWithUI({"Take", "Read", "Book"})

                if hasTakenBook then
                    task.wait(1)

                    -------------------------------------------------
                    -- PASSO 2: Achar Assento e Sentar
                    -------------------------------------------------
                    local randomSeatTarget = GetRandomObject(SeatObjects)

                    if randomSeatTarget then
                        if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Buscando assento: " .. randomSeatTarget.Name, Color3.fromRGB(200, 200, 200)) end

                        -- Mandando o objeto final direto pro seu SmartDoor!
                        if _G.SmartDoor and _G.SmartDoor.IrPara then
                            _G.SmartDoor.IrPara(randomSeatTarget)
                        end

                        task.wait(1)

                        -- Checa se aparece "Sit" ou "Use" e aperta E
                        local hasSat = InteractWithUI({"Sit", "Use"})

                        if hasSat then
                            if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Lendo...", Color3.fromRGB(100, 255, 100)) end
                            task.wait(15) 
                        end
                    end
                end
            else
                if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Nenhum livro encontrado na casa!", Color3.fromRGB(255, 100, 100)) end
                task.wait(5)
            end

            task.wait(1)
        end
    end)
end

function _G.Intelligence.Stop()
    isFarmingIntel = false
    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência parado.", Color3.fromRGB(255, 100, 100)) end
end

return _G.Intelligence
