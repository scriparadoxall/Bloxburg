_G.Intelligence = {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local isFarmingIntel = false
local currentMacroId = 0

-- Configurações
local BookObjects = {"Bookcase", "Dresser", "Table", "Books", "Book"}
local SeatObjects = {"Sofa", "Toilet", "Chair", "Stool", "Bench"} -- CAMA (Bed) REMOVIDA

local function CarregarModulo(nomeExato)
    local url = "https://raw.githubusercontent.com/scriparadoxall/Bloxburg/main/" .. nomeExato
    local s, r = pcall(function() return loadstring(game:HttpGet(url))() end)
    return s and r or nil
end

local function GetPlayerHouse()
    local p = workspace.Plots:FindFirstChild("Plot_" .. Players.LocalPlayer.Name)
    return p and p:FindFirstChild("House") or nil
end

local function GetTarget(list)
    local house = GetPlayerHouse()
    local folder = house and house:FindFirstChild("Objects")
    if not folder then return nil end
    local found = {}
    for _, obj in ipairs(folder:GetChildren()) do
        for _, name in ipairs(list) do
            if string.find(string.lower(obj.Name), string.lower(name)) then table.insert(found, obj) break end
        end
    end
    if #found > 0 then
        local chosen = found[math.random(1, #found)]
        local part = chosen:FindFirstChild("Books", true) or chosen:FindFirstChild("Door1", true) or chosen:FindFirstChild("Seat", true) or chosen
        return part, chosen.Name
    end
    return nil
end

local function CheckHand()
    local ok, res = pcall(function()
        local label = Players.LocalPlayer.PlayerGui.HUDGui.Hotbar.LayoutContainer.LeftButtonContainer.EquippedContainer.ActionLabel
        return string.lower(label.Text), label.Parent
    end)
    return ok and res or nil
end

function _G.Intelligence.Start()
    if isFarmingIntel then return end
    isFarmingIntel = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId

    task.spawn(function()
        while isFarmingIntel and currentMacroId == myId do
            local char = Players.LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if not hum then task.wait(1) continue end

            local handText = CheckHand()
            local temLivro = handText and (handText:find("use") or handText:find("read") or handText:find("ler"))

            -- 1. PEGAR LIVRO
            if not temLivro and not hum.Sit then
                local bookPart, name = GetTarget(BookObjects)
                if bookPart then
                    local door = CarregarModulo("smart_door.lua")
                    if door then door.IrPara(bookPart) end
                    
                    local cam = CarregarModulo("smart_cam")
                    if cam then cam.OlharPara(bookPart) end
                    
                    -- Interage
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(0.1); VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    
                    task.wait(2) -- Tempo para o item ir para a mão
                    if cam then cam.Reset() end
                end

            -- 2. SENTAR E LER
            elseif temLivro then
                if not hum.Sit then
                    local seatPart, name = GetTarget(SeatObjects)
                    if seatPart then
                        local door = CarregarModulo("smart_door.lua")
                        if door then door.IrPara(seatPart) end
                        
                        local cam = CarregarModulo("smart_cam")
                        if cam then cam.OlharPara(seatPart) end
                        
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                        task.wait(0.1); VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                        
                        task.wait(2)
                        if cam then cam.Reset() end
                    end
                else
                    -- JÁ ESTÁ SENTADO LENDO
                    task.wait(15)
                    hum.Jump = true -- Levanta para reciclar o farm
                    task.wait(1)
                end
            end
            task.wait(1)
        end
    end)
end

function _G.Intelligence.Stop()
    isFarmingIntel = false
    currentMacroId = currentMacroId + 1
    local cam = CarregarModulo("smart_cam")
    if cam then cam.Reset() end
end

return _G.Intelligence
