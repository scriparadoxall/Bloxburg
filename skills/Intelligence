_G.Intelligence = {}

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local isFarmingIntel = false
local currentMacroId = 0

---------------------------------------------------------
-- GERENCIADOR DE MÓDULOS (Cache)
---------------------------------------------------------
local ModulosCarregados = {}

local function CarregarModulo(nomeExato)
    if ModulosCarregados[nomeExato] then return ModulosCarregados[nomeExato] end

    local url = "https://raw.githubusercontent.com/scriparadoxall/Bloxburg/main/" .. nomeExato
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)

    if success and result then
        ModulosCarregados[nomeExato] = result
        return result
    end
    return nil
end

---------------------------------------------------------
-- LISTAS DE ALVOS (Sem camas para evitar bugs de deitar)
---------------------------------------------------------
local BookObjects = {"Bookcase", "Dresser", "Table", "Books", "Book"}
local SeatObjects = {"Sofa", "Toilet", "Chair", "Stool", "Bench"}

---------------------------------------------------------
-- FUNÇÕES AUXILIARES DE LOCALIZAÇÃO
---------------------------------------------------------
local function GetPlayerHouse()
    local plots = workspace:FindFirstChild("Plots")
    local myPlot = plots and plots:FindFirstChild("Plot_" .. Players.LocalPlayer.Name)
    if myPlot then return myPlot:FindFirstChild("House") end
    
    for _, plot in ipairs(plots:GetChildren()) do
        local owner = plot:FindFirstChild("Owner")
        if owner and (owner.Value == Players.LocalPlayer or owner.Value == Players.LocalPlayer.Name) then
            return plot:FindFirstChild("House")
        end
    end
    return nil
end

local function GetTarget(list)
    local house = GetPlayerHouse()
    local folder = house and house:FindFirstChild("Objects")
    if not folder then return nil end
    
    local found = {}
    for _, obj in ipairs(folder:GetChildren()) do
        for _, name in ipairs(list) do
            if string.find(string.lower(obj.Name), string.lower(name)) then table.insert(found, obj) break end
        end
    end
    
    if #found > 0 then
        local chosen = found[math.random(1, #found)]
        local part = chosen
        
        -- Procura a peça de interação correta (ObjectModel ou ItemHolder)
        if chosen:FindFirstChild("ObjectModel") then
            part = chosen.ObjectModel:FindFirstChild("Books") or chosen.ObjectModel:FindFirstChild("Seat") or chosen.ObjectModel:FindFirstChild("Door1") or chosen
        elseif chosen:FindFirstChild("ItemHolder") then
            part = chosen.ItemHolder:FindFirstChildWhichIsA("BasePart") or chosen
        end
        return part, chosen.Name
    end
    return nil
end

-- Verifica se o livro está realmente na mão através da UI
local function CheckHand()
    local ok, res = pcall(function()
        local eqContainer = Players.LocalPlayer.PlayerGui.HUDGui.Hotbar.LayoutContainer.LeftButtonContainer.EquippedContainer
        if eqContainer and eqContainer.Visible then
            local label = eqContainer:FindFirstChild("ActionLabel")
            if label then return string.lower(label.Text) end
        end
        return ""
    end)
    return ok and res or ""
end

-- FUNÇÃO CRÍTICA: Aguarda a UI e aperta E como a última ação
local function InteractSafe(validWords)
    local playerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
    local timeout = tick() + 2.5 -- Tenta detetar o botão por 2.5 segundos
    
    while tick() < timeout do
        local interactUI = playerGui:FindFirstChild("_interactUI")
        if interactUI then
            local indicator = interactUI:FindFirstChild("InteractIndicator")
            if indicator and indicator.Visible then
                local textLabel = indicator:FindFirstChild("TextLabel")
                if textLabel then
                    local txt = string.lower(textLabel.Text)
                    for _, word in ipairs(validWords) do
                        if string.find(txt, word) then
                            -- A câmara parou, o botão apareceu: AGORA aperta E
                            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                            task.wait(0.1)
                            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                            return true
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
    return false
end

local function ForcarResetCamera()
    pcall(function()
        local cam = CarregarModulo("smart_cam")
        if cam and cam.Reset then cam.Reset() end
        
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        workspace.CurrentCamera.CameraSubject = Players.LocalPlayer.Character.Humanoid
    end)
end

---------------------------------------------------------
-- LOOP PRINCIPAL (Fluxo: Andar -> Focar -> Esperar -> E)
---------------------------------------------------------
function _G.Intelligence.Start()
    if isFarmingIntel then return end
    isFarmingIntel = true
    currentMacroId = currentMacroId + 1
    local myId = currentMacroId

    if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Farm de Inteligência Iniciado!", Color3.fromRGB(150, 150, 255)) end

    task.spawn(function()
        while isFarmingIntel and currentMacroId == myId do
            local char = Players.LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if not hum then task.wait(1) continue end

            local handText = CheckHand()
            local temLivro = (handText ~= "") and (string.find(handText, "use") or string.find(handText, "read") or string.find(handText, "ler"))

            -- PASSO 1: PEGAR O LIVRO
            if not temLivro and not hum.Sit then
                local bookPart, bookName = GetTarget(BookObjects)
                if bookPart then
                    local door = CarregarModulo("smart_door.lua")
                    if door then door.IrPara(bookPart) end
                    
                    local cam = CarregarModulo("smart_cam")
                    if cam then 
                        cam.OlharPara(bookPart) 
                        task.wait(0.3) -- Pausa obrigatória para a UI do "E" carregar após o foco
                    end
                    
                    -- INTERAÇÃO (Aperta E após tudo estabilizar)
                    InteractSafe({"take", "read", "book", "ler", "pegar"})
                    
                    ForcarResetCamera()
                    task.wait(2.5) -- Tempo para o livro aparecer na mão
                end
                
            -- PASSO 2: IR SENTAR (Apenas se tiver o livro)
            elseif temLivro and not hum.Sit then
                local seatPart, seatName = GetTarget(SeatObjects)
                if seatPart then
                    local door = CarregarModulo("smart_door.lua")
                    if door then door.IrPara(seatPart) end
                    
                    local cam = CarregarModulo("smart_cam")
                    if cam then 
                        cam.OlharPara(seatPart)
                        task.wait(0.3)
                    end
                    
                    -- INTERAÇÃO (Aperta E para sentar)
                    InteractSafe({"sit", "use", "sentar", "usar"})
                    
                    ForcarResetCamera()
                    task.wait(2) 
                end
                
            -- PASSO 3: LER (Sentado e equipado)
            elseif temLivro and hum.Sit then
                if _G.BloxburgChef_AddLog then _G.BloxburgChef_AddLog("Lendo livro...", Color3.fromRGB(100, 255, 100)) end
                for i=1, 15 do
                    if not isFarmingIntel or currentMacroId ~= myId or hum.Sit == false then break end
                    task.wait(1)
                end
                
                -- Levanta para recomeçar o ciclo
                hum.Jump = true 
                task.wait(1)
            end
            
            task.wait(0.5)
        end
    end)
end

function _G.Intelligence.Stop()
    isFarmingIntel = false
    currentMacroId = currentMacroId + 1
    ForcarResetCamera()
    local door = CarregarModulo("smart_door.lua")
    if door and door.Cancelar then door.Cancelar() end
end

return _G.Intelligence
