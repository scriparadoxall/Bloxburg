local Players = game:GetService("Players")
local PathfindingService = game:GetService("PathfindingService")

local LocalPlayer = Players.LocalPlayer
local StationFinder = {}

local function DeixarPortasFantasmas()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("House") and plot.House:FindFirstChild("Walls") then
            for _, obj in pairs(plot.House.Walls:GetDescendants()) do
                if obj:IsA("BasePart") then
                    local nome = string.lower(obj.Name)
                    local nomePai = obj.Parent and string.lower(obj.Parent.Name) or ""
                    
                    if string.find(nome, "door") or string.find(nomePai, "door") then
                        if not obj:FindFirstChild("IgnorarNoGPS") then
                            local modifier = Instance.new("PathfindingModifier")
                            modifier.Name = "IgnorarNoGPS"
                            modifier.PassThrough = true
                            modifier.Parent = obj
                        end
                    end
                end
            end
        end
    end
end

local function GetWalkingDistance(startPos, endPos)
    local path = PathfindingService:CreatePath({
        AgentRadius = 1.2,
        AgentHeight = 5,
        AgentCanJump = true,
        WaypointSpacing = 3
    })

    local success, _ = pcall(function()
        path:ComputeAsync(startPos, endPos)
    end)

    if success and path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()
        local totalDistance = 0
        
        for i = 1, #waypoints - 1 do
            totalDistance = totalDistance + (waypoints[i].Position - waypoints[i+1].Position).Magnitude
        end
        return totalDistance
    end
    
    return math.huge 
end

local function GetInteractionPart(obj)
    local objectModel = obj:FindFirstChild("ObjectModel")
    if objectModel then
        local door = objectModel:FindFirstChild("OvenDoor") 
                  or objectModel:FindFirstChild("MainDoor") 
                  or objectModel:FindFirstChild("Door")
                  or objectModel:FindFirstChild("Handle")
        
        if door then
            if door:IsA("Model") then
                return door.PrimaryPart or door:FindFirstChildWhichIsA("BasePart", true) or door
            end
            return door
        end
    end
    return obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)) or obj
end

function StationFinder.Find(stationType)
    DeixarPortasFantasmas()
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil, nil, math.huge end
    local myPos = character.HumanoidRootPart.Position

    local nearestObject = nil
    local nearestPart = nil
    local shortestWalkingDist = math.huge

    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil, nil, math.huge end

    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("House") and plot.House:FindFirstChild("Counters") then
            for _, obj in pairs(plot.House.Counters:GetChildren()) do
                local objName = string.lower(obj.Name)
                local match = false
                
                if stationType == "geladeira" or stationType == "fridge" then
                    if string.find(objName, "fridge") or string.find(objName, "refrigerator") or string.find(objName, "icebox") then match = true end
                elseif stationType == "fogao" or stationType == "stove" then
                    if string.find(objName, "stove") or string.find(objName, "oven") or string.find(objName, "cook") or string.find(objName, "range") then match = true end
                elseif stationType == "bancada" or stationType == "counter" then
                    if string.find(objName, "counter") or string.find(objName, "island") then match = true end
                end

                if match then
                    local interactPart = GetInteractionPart(obj)
                    if interactPart then
                        local walkDist = GetWalkingDistance(myPos, interactPart.Position)
                        
                        if walkDist == math.huge then
                            walkDist = (myPos - interactPart.Position).Magnitude
                        end
                        
                        if walkDist < shortestWalkingDist then
                            shortestWalkingDist = walkDist
                            nearestObject = obj
                            nearestPart = interactPart
                        end
                    end
                end
            end
        end
    end

    return nearestObject, nearestPart, shortestWalkingDist
end

return StationFinder
