local SmartCam = {}
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

function SmartCam.OlharPara(alvoPart)
    local Camera = workspace.CurrentCamera
    local char = Players.LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local alvoPos = alvoPart:IsA("Model") and (alvoPart.PrimaryPart and alvoPart.PrimaryPart.Position or alvoPart:GetPivot().Position) or alvoPart.Position
    local headPos = char:FindFirstChild("Head") and char.Head.Position or (hrp.Position + Vector3.new(0, 1.5, 0))

    local direcaoCorpo = CFrame.new(hrp.Position, Vector3.new(alvoPos.X, hrp.Position.Y, alvoPos.Z))
    local offsets = {
        Vector3.new(0, 2.5, 4),   -- Atrás
        Vector3.new(3, 2, 2),     -- Direita
        Vector3.new(-3, 2, 2),    -- Esquerda
        Vector3.new(0, 4, 1)      -- Cima
    }

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char, alvoPart.Parent, workspace:FindFirstChild("Plots")}

    local melhorPos = headPos + Vector3.new(0, 2.5, 3)

    for _, offset in ipairs(offsets) do
        local posTeste = (direcaoCorpo * CFrame.new(offset)).Position
        local resultado = workspace:Raycast(headPos, posTeste - headPos, rayParams)
        if not resultado then
            melhorPos = posTeste
            break
        end
    end

    Camera.CameraType = Enum.CameraType.Scriptable
    
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local tween = TweenService:Create(Camera, tweenInfo, {
        CFrame = CFrame.lookAt(melhorPos, alvoPos)
    })
    
    tween:Play()
    tween.Completed:Wait() -- Espera o movimento terminar
end

function SmartCam.Reset()
    local Camera = workspace.CurrentCamera
    local char = Players.LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    
    -- Força a câmera voltar ao normal e grudar no boneco
    Camera.CameraType = Enum.CameraType.Custom
    if hum then
        Camera.CameraSubject = hum
    end
end

return SmartCam
