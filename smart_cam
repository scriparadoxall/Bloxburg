local guiName = "SmartCamTestGUI"

-- Limpa a GUI antiga se existir
if CoreGui:FindFirstChild(guiName) then
    CoreGui[guiName]:Destroy()
end

-- ==========================================
-- 🎯 LÓGICA DE ACHAR A PEÇA DE INTERAÇÃO EXATA
-- ==========================================
local function GetInteractionPart(obj)
    local objectModel = obj:FindFirstChild("ObjectModel")
    if objectModel then
        local door = objectModel:FindFirstChild("OvenDoor") 
                  or objectModel:FindFirstChild("MainDoor") 
                  or objectModel:FindFirstChild("Door")
                  or objectModel:FindFirstChild("Handle") 
                  or objectModel:FindFirstChild("Top") 

        if door then
            if door:IsA("Model") then
                return door.PrimaryPart or door:FindFirstChildWhichIsA("BasePart", true) or door
            end
            return door
        end
    end
    return obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)) or obj
end

local function AcharMovelMaisPerto(tipoMovel)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position

    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end

    local alvoEncontradoPart = nil
    local menorDistancia = math.huge

    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("House") and plot.House:FindFirstChild("Counters") then
            for _, obj in pairs(plot.House.Counters:GetChildren()) do
                local nome = string.lower(obj.Name)
                local match = false

                if tipoMovel == "geladeira" and (string.find(nome, "fridge") or string.find(nome, "refrigerator")) then match = true
                elseif tipoMovel == "fogao" and (string.find(nome, "stove") or string.find(nome, "oven")) then match = true
                elseif tipoMovel == "bancada" and (string.find(nome, "counter") or string.find(nome, "island")) then match = true
                end

                if match then
                    local part = GetInteractionPart(obj)
                    if part then
                        local dist = (myPos - part.Position).Magnitude
                        if dist < menorDistancia then
                            menorDistancia = dist
                            alvoEncontradoPart = part
                        end
                    end
                end
            end
        end
    end
    return alvoEncontradoPart
end

-- ==========================================
-- 🎥 LÓGICA DA CÂMERA (POR CIMA DO OMBRO)
-- ==========================================
local function MoverCameraSuave(alvoPart)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart

    -- MATEMÁTICA DO OMBRO: 
    -- X = 2.5 (Para a direita do corpo)
    -- Y = 2.5 (Para cima da cabeça)
    -- Z = 8.0 (Para trás)
    local posicaoNoOmbro = hrp.CFrame:PointToWorldSpace(Vector3.new(2.5, 2.5, 8))

    -- Foca exatamente na porta/tampo para o jogo não esconder o botão
    local alvoPos = alvoPart:IsA("Model") and alvoPart:GetPivot().Position or alvoPart.Position

    -- Cria a posição da câmera olhando pro alvo
    local cframeDesejado = CFrame.lookAt(posicaoNoOmbro, alvoPos)

    local tweenInfo = TweenInfo.new(
        0.5, 
        Enum.EasingStyle.Sine, 
        Enum.EasingDirection.Out
    )

    Camera.CameraType = Enum.CameraType.Scriptable

    local tween = TweenService:Create(Camera, tweenInfo, {CFrame = cframeDesejado})
    tween:Play()
    tween.Completed:Wait()

    -- Força o foco da câmera no alvo para o Bloxburg reconhecer a intenção de interagir!
    Camera.Focus = CFrame.new(alvoPos)

    -- Devolve o controle pro jogador girar se quiser
    Camera.CameraType = Enum.CameraType.Custom
end

