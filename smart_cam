local function MoveToStation(stationType)
    -- 1. SEARCH: Procura o objeto e a peça de interação exata
    local searcher = CarregarModulo("smartSearch")
    if not searcher then return false end

    local obj, part, dist = searcher.Find(stationType)
    if not obj or not part then 
        Log("ERRO: Nenhuma '" .. stationType .. "' acessível!", Color3.fromRGB(255, 100, 100))
        return false 
    end

    -- 2. DOOR: Anda exatamente até a peça encontrada
    local doorSystem = CarregarModulo("smart_door.lua")
    if not doorSystem then return false end

    local chegou_no_destino = doorSystem.IrPara(part)

    -- 3. CHEGOU? Arruma a câmera e aperta E!
    if chegou_no_destino then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        
        -- Vira o corpo do boneco de frente para o móvel
        hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(part.Position.X, hrp.Position.Y, part.Position.Z))
        
        -- CAM: Recebe a MESMA peça que o search achou e foca nela
        local camSystem = CarregarModulo("smart_cam")
        if camSystem then
            camSystem.OlharPara(part)
        end

        -- FOOD: Clica!
        task.wait(0.2)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        return true
    end

    return false
end