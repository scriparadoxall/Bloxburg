local PathfindingService = game:GetService("PathfindingService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")

local SmartDoor = {} 
SmartDoor.CurrentWalkId = 0 
local lastDoorClick = 0

local function LogSD(msg)
    if _G.BloxburgChef_AddLog then
        _G.BloxburgChef_AddLog(msg, Color3.fromRGB(255, 170, 0))
    else
        print("[SmartDoor] " .. msg)
    end
end

-- ==========================================
-- 🚪 LEITOR DA INTERFACE (CAMINHO EXATO QUE VOCÊ PASSOU)
-- ==========================================
local function LerStatusDaPorta()
    local player = Players.LocalPlayer
    local success, result = pcall(function()
        -- Usando o caminho que você forneceu
        local ui = player.PlayerGui._interactUI.InteractIndicator.TextLabel
        return string.lower(ui.Text)
    end)
    
    if success then return result end
    return nil
end

-- ==========================================
-- 👻 GPS: TRATAR PORTAS COMO AR (FANTASMAS)
-- ==========================================
local function AlterarFantasmas(estado)
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, plot in pairs(plots:GetChildren()) do
        if plot:FindFirstChild("House") then
            for _, obj in pairs(plot.House:GetDescendants()) do
                if obj:IsA("Model") and (string.find(string.lower(obj.Name), "door") or string.find(string.lower(obj.Name), "gate")) then
                    for _, part in pairs(obj:GetDescendants()) do
                        if part:IsA("BasePart") then
                            if estado == "LIGAR" then
                                if not part:FindFirstChild("IgnorarNoGPS") then
                                    local mod = Instance.new("PathfindingModifier")
                                    mod.Name = "IgnorarNoGPS"
                                    mod.PassThrough = true
                                    mod.Parent = part
                                end
                            elseif estado == "DESLIGAR" then
                                local mod = part:FindFirstChild("IgnorarNoGPS")
                                if mod then mod:Destroy() end
                            end
                        end
                    end
                end
            end
        end
    end
end

function SmartDoor.Cancelar()
    SmartDoor.CurrentWalkId = SmartDoor.CurrentWalkId + 1
    pcall(function()
        local char = Players.LocalPlayer.Character
        char.Humanoid:MoveTo(char.HumanoidRootPart.Position)
    end)
end

function SmartDoor.IrPara(destino)
    SmartDoor.CurrentWalkId = SmartDoor.CurrentWalkId + 1
    local myWalkId = SmartDoor.CurrentWalkId 

    local player = Players.LocalPlayer
    local char = player.Character
    if not char or not char:FindFirstChild("Humanoid") then return false end
    local hum = char.Humanoid
    local hrp = char.HumanoidRootPart

    local targetPos = typeof(destino) == "Instance" and (destino:IsA("Model") and destino:GetPivot().Position or destino.Position) or destino

    -- 1. Faz o GPS ignorar as portas para calcular a rota "por dentro" delas
    AlterarFantasmas("LIGAR")
    
    local path = PathfindingService:CreatePath({
        AgentRadius = 0.5, -- Boneco fino para passar na porta
        AgentHeight = 5,
        AgentCanJump = true,
        WaypointSpacing = 3
    })

    local success, _ = pcall(function() path:ComputeAsync(hrp.Position, targetPos) end)
    AlterarFantasmas("DESLIGAR") -- Volta o mundo ao normal para a física

    if not success or path.Status ~= Enum.PathStatus.Success then
        LogSD("⚠️ Rota falhou. Indo em linha reta.")
        hum:MoveTo(targetPos)
        return false
    end

    local waypoints = path:GetWaypoints()
    
    for i, wp in ipairs(waypoints) do
        if SmartDoor.CurrentWalkId ~= myWalkId then return false end
        
        hum:MoveTo(wp.Position)

        -- Enquanto não chegar no ponto do GPS
        while (hrp.Position - wp.Position).Magnitude > 3 do
            if SmartDoor.CurrentWalkId ~= myWalkId then return false end
            
            -- LÓGICA DA PORTA BASEADA NA SUA UI
            local status = LerStatusDaPorta()
            
            if status == "open" then
                -- Se está escrito "Open", a porta está FECHADA. Para e abre.
                LogSD("🚪 Porta fechada detectada! Abrindo...")
                hum:MoveTo(hrp.Position) -- Freia o boneco
                
                -- Aperta E
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(0.1)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                
                -- Espera ela mudar para "Close" ou sumir (indicando que abriu)
                local tempoEspera = tick()
                while tick() - tempoEspera < 3 do
                    local novoStatus = LerStatusDaPorta()
                    if novoStatus == "close" or novoStatus == nil then break end
                    task.wait(0.1)
                end
                
                LogSD("🔓 Porta aberta. Seguindo caminho...")
                hum:MoveTo(wp.Position) -- Retoma a caminhada
            
            elseif status == "close" then
                -- Se está escrito "Close", ela já está aberta. Não faz nada, só continua.
                -- O boneco vai passar direto por ela.
            end

            -- Checagem de distância final do objeto
            if (hrp.Position - targetPos).Magnitude < 4 then
                hum:MoveTo(hrp.Position)
                return true
            end
            
            task.wait()
        end
    end

    return true
end

return SmartDoor
