local SmartCam = {}
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

function SmartCam.OlharPara(alvoPart)
    local Camera = workspace.CurrentCamera
    local char = Players.LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not hum then return end

    -- Trava a rotação do boneco para ele não girar como robô
    hum.AutoRotate = false 

    local headPos = char:FindFirstChild("Head") and char.Head.Position or (hrp.Position + Vector3.new(0, 1.5, 0))
    local alvoPos = alvoPart:IsA("Model") and (alvoPart.PrimaryPart and alvoPart.PrimaryPart.Position or alvoPart:GetPivot().Position) or alvoPart.Position

    -- Calcula a direção baseada em onde o boneco já está parado
    local direcaoCorpo = CFrame.new(hrp.Position, Vector3.new(alvoPos.X, hrp.Position.Y, alvoPos.Z))

    -- Lista de posições para a câmera testar (Atrás, Lados, Cima)
    local offsets = {
        Vector3.new(0, 3, 5),   -- Atrás e cima
        Vector3.new(4, 2, 3),   -- Lado Direito
        Vector3.new(-4, 2, 3),  -- Lado Esquerdo
        Vector3.new(0, 6, 0.5)  -- Visão de cima (anti-parede total)
    }

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char, alvoPart.Parent, workspace:FindFirstChild("Plots")}

    local melhorPos = headPos + Vector3.new(0, 3, 2) -- Posição de reserva

    for _, offset in ipairs(offsets) do
        local posTeste = (direcaoCorpo * CFrame.new(offset)).Position
        local direcaoRay = posTeste - headPos
        local resultado = workspace:Raycast(headPos, direcaoRay, rayParams)

        if not resultado then
            melhorPos = posTeste -- Caminho livre!
            break
        elseif (resultado.Position - headPos).Magnitude > 3 then
            melhorPos = resultado.Position - (direcaoRay.Unit * 0.5) -- Perto da parede, mas visível
            break
        end
    end

    -- Move a câmera suavemente
    Camera.CameraType = Enum.CameraType.Scriptable
    local tween = TweenService:Create(Camera, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        CFrame = CFrame.lookAt(melhorPos, alvoPos)
    })
    tween:Play()
    tween.Completed:Wait()
end

function SmartCam.Reset()
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    if Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
        Players.LocalPlayer.Character.Humanoid.AutoRotate = true
    end
end

return SmartCam
